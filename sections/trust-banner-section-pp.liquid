          "default": "100% Natural Ingredients"
        }
      ]
    },
    {
      "type": "badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon_type",
          "label": "Icon Type",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "microscope",
              "label": "Microscope (Clinically Backed)"
            },
            {
              "value": "shield",
              "label": "Shield (Third Party Tested)"
            },
            {
              "value": "flask",
              "label": "Flask (Clean Formulas)"
            },
            {
              "value": "globe",
              "label": "Globe (Globally Trusted)"
            },
            {
              "value": "leaf",
              "label": "Leaf (Natural)"
            },
            {
              "value": "certificate",
              "label": "Certificate (Certified)"
            }
          ],
          "default": "microscope"
        },
        {
          "type": "text",
          "id": "badge_title",
          "label": "Badge Title",
          "default": "Clinically"
        },
        {
          "type": "text",
          "id": "badge_subtitle",
          "label": "Badge Subtitle",
          "default": "Backed Formulas"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Banner - OWELL pp",
      "blocks": [
        {
          "type": "top_feature",
          "settings": {
            "feature_text": "Professional-Grade Quality"
          }
        },
        {
          "type": "top_feature",
          "settings": {
            "feature_text": "Trusted Since 2016"
          }
        },
        {
          "type": "top_feature",
          "settings": {
            "feature_text": "Latex-Free Options"
          }
        },
        {
          "type": "top_feature",
          "settings": {
            "feature_text": "Gamma Sterilized"
          }
        },
        {
          "type": "top_feature",
          "settings": {
            "feature_text": "Bulk Pricing Available"
          }
        },
        {
          "type": "top_feature",
          "settings": {
            "feature_text": "Fast, Dependable Shipping"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon_type": "shield",
            "badge_title": "ISO",
            "badge_subtitle": "Certified Standards"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon_type": "microscope",
            "badge_title": "Electronically",
            "badge_subtitle": "Tested"
          }
        },
        {
          "type": "badge",
          "settings": {
