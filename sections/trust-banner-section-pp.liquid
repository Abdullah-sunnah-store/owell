{% comment %}
  Trust Banner Section for Owell Naturals
  Displays brand trust indicators with icons and customizable content
{% endcomment %}

<section class="trust-banner-section" data-section-id="{{ section.id }}" data-section-type="trust-banner">
  <div class="trust-banner-wrapper" style="background-color: {{ section.settings.background_color }};">
    <div class="page-width">
      
      {% if section.settings.heading != blank %}
        <h2 class="trust-banner__heading" style="color: {{ section.settings.text_color }};">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {%- if section.settings.show_top_features -%}
        <div class="trust-banner__top-features">
          {%- for block in section.blocks -%}
            {%- if block.type == 'top_feature' -%}
              <div class="trust-banner__top-feature" {{ block.shopify_attributes }}>
                <svg class="trust-banner__checkmark" width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <circle cx="10" cy="10" r="9" stroke="{{ section.settings.text_color }}" stroke-width="1.5"/>
                  <path d="M6 10L9 13L14 7" stroke="{{ section.settings.text_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span style="color: {{ section.settings.text_color }};">{{ block.settings.feature_text }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="trust-banner__badges">
        {%- for block in section.blocks -%}
          {%- if block.type == 'badge' -%}
            <div class="trust-banner__badge" {{ block.shopify_attributes }}>
              <div class="trust-banner__badge-inner" style="border-color: {{ section.settings.badge_border_color }};">
                
                {%- if block.settings.icon_type != 'none' -%}
                  <div class="trust-banner__icon">
                    {%- case block.settings.icon_type -%}
                      {%- when 'microscope' -%}
                        <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="{{ section.settings.text_color }}" stroke-width="1.5">
                          <circle cx="20" cy="12" r="4"/>
                          <path d="M20 16v8M16 24h8M12 32h16M20 24l-4 8M20 24l4 8"/>
                          <circle cx="26" cy="10" r="2"/>
                        </svg>
                      {%- when 'shield' -%}
                        <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="{{ section.settings.text_color }}" stroke-width="1.5">
                          <path d="M20 4L8 10v8c0 7.5 5.2 14.5 12 16 6.8-1.5 12-8.5 12-16v-8L20 4z"/>
                          <path d="M14 20l4 4 8-8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      {%- when 'flask' -%}
                        <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="{{ section.settings.text_color }}" stroke-width="1.5">
                          <path d="M16 4h8M18 4v8l-6 12v8c0 2.2 1.8 4 4 4h8c2.2 0 4-1.8 4-4v-8l-6-12V4"/>
                          <circle cx="20" cy="24" r="1.5" fill="{{ section.settings.text_color }}"/>
                          <circle cx="24" cy="26" r="1" fill="{{ section.settings.text_color }}"/>
                        </svg>
                      {%- when 'globe' -%}
                        <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="{{ section.settings.text_color }}" stroke-width="1.5">
                          <circle cx="20" cy="20" r="14"/>
                          <path d="M6 20h28M20 6c-3.3 0-6 6.3-6 14s2.7 14 6 14 6-6.3 6-14-2.7-14-6-14z"/>
                          <path d="M10 12c2.5 2 5.8 3 9 3s6.5-1 9-3M10 28c2.5-2 5.8-3 9-3s6.5 1 9 3"/>
                        </svg>
                      {%- when 'leaf' -%}
                        <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="{{ section.settings.text_color }}" stroke-width="1.5">
                          <path d="M10 30c0-11 9-20 20-20-11 0-20 9-20 20 0 2.2 1.8 4 4 4h12c2.2 0 4-1.8 4-4"/>
                          <path d="M14 18c4 4 8 8 12 12"/>
                        </svg>
                      {%- when 'certificate' -%}
                        <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="{{ section.settings.text_color }}" stroke-width="1.5">
                          <rect x="6" y="8" width="28" height="20" rx="2"/>
                          <path d="M12 14h16M12 18h12M12 22h8"/>
                          <circle cx="28" cy="26" r="4"/>
                          <path d="M26 32l2-4 2 4" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    {%- endcase -%}
                  </div>
                {%- endif -%}

                <div class="trust-banner__badge-text">
                  {%- if block.settings.badge_title != blank -%}
                    <h3 class="trust-banner__badge-title" style="color: {{ section.settings.text_color }};">
                      {{ block.settings.badge_title }}
                    </h3>
                  {%- endif -%}
                  {%- if block.settings.badge_subtitle != blank -%}
                    <p class="trust-banner__badge-subtitle" style="color: {{ section.settings.text_color }};">
                      {{ block.settings.badge_subtitle }}
                    </p>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

<style>

  .trust-banner-wrapper {
    position: relative;
    overflow: hidden;
    padding: 40px 0;
  }

  .trust-banner-wrapper::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .trust-banner__heading {
    text-align: center;
    font-size: 28px;
    font-weight: 600;
    margin: 0 0 30px;
    letter-spacing: -0.02em;
  }

  .trust-banner__top-features {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px 32px;
    margin-bottom: 40px;
  }

  .trust-banner__top-feature {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 500;
  }

  .trust-banner__checkmark {
    flex-shrink: 0;
  }

  .trust-banner__badges {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .trust-banner__badge {
    display: flex;
    justify-content: center;
  }

  .trust-banner__badge-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 24px 20px;
    border: 1.5px solid;
    border-radius: 8px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    width: 100%;
    max-width: 240px;
  }

  .trust-banner__badge-inner:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0,0,0,0.15);
  }

  .trust-banner__icon {
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .trust-banner__badge-title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin: 0 0 4px;
    line-height: 1.3;
  }

  .trust-banner__badge-subtitle {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin: 0;
    line-height: 1.3;
  }

  @media screen and (max-width: 768px) {
    .trust-banner-section {
      padding: 30px 0;
    }

    .trust-banner__heading {
      font-size: 22px;
      margin-bottom: 24px;
    }

    .trust-banner__top-features {
      gap: 16px 24px;
      margin-bottom: 30px;
    }

    .trust-banner__top-feature {
      font-size: 13px;
    }

    .trust-banner__badges {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .trust-banner__badge-inner {
      padding: 20px 16px;
    }
  }

  @media screen and (max-width: 480px) {
    .trust-banner__badges {
      grid-template-columns: 1fr;
    }

    .trust-banner__top-features {
      flex-direction: row;
      align-items: flex-start;
      gap: 12px;
    }
  }
</style>

{% schema %}
{
  "name": "Trust Banner pp",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Quality & Reliability You Can Count On"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#026EB4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_border_color",
      "label": "Badge Border Color",
      "default": "#56C2B3"
    },
    {
      "type": "checkbox",
      "id": "show_top_features",
      "label": "Show Top Features",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "top_feature",
