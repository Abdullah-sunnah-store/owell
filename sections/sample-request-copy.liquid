      "label": "Button 2 Label",
      "default": "Apply for Business Account"
    },
    {
      "type": "url",
      "id": "success_btn2_url",
      "label": "Button 2 URL"
    }
  ],
  "presets": [
    {
      "name": "sample request copy"
    }
  ]
}
{% endschema %}
