{% comment %}
  Announcement Bar Section
  Displays promotional message - single line on desktop, two lines on mobile
{% endcomment %}

<style>
  .announcement-bar-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    text-align: center;
    padding: 12px 20px;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    width: 100%;
    {% if section.settings.enable_sticky %}
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    z-index: 9999 !important;
    {% else %}
    position: relative;
    z-index: 10;
    {% endif %}
  }

  .announcement-bar__content-{{ section.id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Add body padding when sticky is enabled to prevent content jump */
  {% if section.settings.enable_sticky %}
  body {
    padding-top: 44px;
  }
  
  @media (max-width: 749px) {
    body {
      padding-top: 48px;
    }
  }
  {% endif %}

  /* Desktop: Single line */
  @media (min-width: 750px) {
    .announcement-bar-{{ section.id }} {
      padding: 10px 20px;
    }
    
    .announcement-bar__text-{{ section.id }} {
      display: inline;
    }
    
    .announcement-bar__break-{{ section.id }} {
      display: none;
    }
  }

  /* Mobile: Two lines */
  @media (max-width: 749px) {
    .announcement-bar-{{ section.id }} {
      font-size: 14px;
      padding: 10px 15px;
    }
    
    .announcement-bar__text-{{ section.id }} {
      display: block;
    }
    
    .announcement-bar__break-{{ section.id }} {
      display: block;
      height: 2px;
    }
  }
</style>

<div class="announcement-bar-{{ section.id }}">
  <div class="announcement-bar__content-{{ section.id }}">
    <span class="announcement-bar__text-{{ section.id }}">
      {{ section.settings.line_1 }}
    </span>
    <span class="announcement-bar__break-{{ section.id }}"></span>
    <span class="announcement-bar__text-{{ section.id }}">
      {{ section.settings.line_2 }}
    </span>
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar cus",
  "settings": [
    {
      "type": "text",
      "id": "line_1",
      "label": "Line 1",
      "default": "15-25% off Business Account ---"
    },
    {
      "type": "text",
      "id": "line_2",
      "label": "Line 2",
      "default": "Free Same Day Shipping"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#5dbaaa"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "Enable Sticky Bar",
      "default": false,
      "info": "Bar will stay at top when scrolling"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar cus"
    }
  ]
}
{% endschema %}
