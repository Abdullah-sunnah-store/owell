    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 Link"
    },
    {
      "type": "checkbox",
      "id": "show_arrow_2",
      "label": "Show Arrow Icon",
      "default": true
    },
    {
      "type": "color",
      "id": "button_2_bg_color",
      "label": "Button 2 Background",
      "default": "rgba(255, 255, 255, 0.2)"
    },
    {
      "type": "color",
      "id": "button_2_hover_bg",
      "label": "Button 2 Hover Background",
      "default": "rgba(255, 255, 255, 0.3)"
    },
    {
      "type": "color",
      "id": "button_2_text_color",
      "label": "Button 2 Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_2_hover_text_color",
      "label": "Button 2 Hover Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Button 3 (Tertiary)"
    },
    {
