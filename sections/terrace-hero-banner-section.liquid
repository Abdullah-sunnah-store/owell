      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_h",
      "label": "Button Horizontal Padding",
      "min": 16,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button Border Radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "header",
      "content": "Button 1 (Primary)"
    },
    {
      "type": "text",
