{% liquid
  assign style_transparent_Header = false
  if section.settings.show_on_only_homepage and request.page_type != 'index'
    assign style_transparent_Header = false

  elsif section.settings.enable_transparent_header
    assign style_transparent_Header = true
  endif
%}
{% style %}
  :root  {
    --sticky-header-enabled: {%- if section.settings.enable_sticky -%}
      1{% else %}
      0{% endif %};
  }

  #shopify-section-{{ section.id }} {
    position:

    {%- if section.settings.enable_sticky  -%}
        sticky
    {% else %}
        relative
    {% endif %};
    z-index: 6;
    top: 0;
    left:0;
    right:0;
  }

  {%- if section.settings.enable_sticky  -%}
    .section-annoucement-bar ~ #shopify-section-{{ section.id }} {
      top: calc(var(--sticky-announcement-enabled, 0) * var(--announcement-height, 0px));
      z-index: 6;
    }
  {%- endif -%}

  .logo {
    height: auto;
    width: {{ section.settings.logo_width | append: "px" }}
    ;
    object-fit: contain;
  }
  .header__nav-list>.nav-item {
    font-size: 18px;
}
  @media(max-width:767px) {
    .logo {
      width: {{ section.settings.logo_mobile_width | append: "px" }}
    }
  }

  /* Always visible search bar styles */
  .header-search-form {
    width: 100%;
  }

  .header-search-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 650px;
    min-width: 200px;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 4px;
    background: white;
    overflow: visible;
  }

  .header-search-input {
    flex: 1;
    border: none;
    padding: 10px 45px 10px 15px;
    font-size: 14px;
    outline: none;
    background: transparent;
    width: 100%;
    min-width: 0;
  }

  .header-search-input::placeholder {
    color: rgba(0, 0, 0, 0.5);
  }

  .header-search-submit {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    background: transparent;
    border: none;
    padding: 0 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .header-search-submit:hover {
    opacity: 0.7;
  }

  .search-bar {
    display: flex;
    align-items: center;
    margin-right: 16px;
    flex: 1;
    max-width: 650px;
  }
.header-search-form {
    width: 600px;
}

@media(min-width:1600px ) and (max-width:1900px){
.header-search-form {
    width: 650px;
}
}
  /* Mobile responsive - hide desktop search bar completely on mobile */
  @media(max-width:991px) {
    .header__iconGroup .search-bar {
      display: none !important;
    }
    .header-search-form {
    width: 100%;
}
  }

  /* Mobile search bar - positioned BELOW menu/logo/cart */
  .mobile-search-container {
    display: none;
    padding: 12px 15px;
    background: var(--color-background, #fff);
  }

  @media(max-width:991px) {
    .mobile-search-container {
      display: block;
    }

    .mobile-search-container .header-search-wrapper {
      max-width: 100%;
      min-width: auto;
    }

    .mobile-search-container .header-search-input {
      font-size: 14px;
      padding: 10px 45px 10px 15px;
    }
  }

  /* Responsive width adjustments for desktop */
  @media(min-width:768px) and (max-width:1024px) {
    .search-bar {
      max-width: 350px;
    }
    
    .header-search-wrapper {
      max-width: 350px;
    }
  }

  @media(min-width:1025px) and (max-width:1200px) {
    .search-bar {
      max-width: 450px;
    }
    
    .header-search-wrapper {
      max-width: 450px;
    }
  }

  @media(min-width:1201px) {
    .search-bar {
      max-width: 650px;
    }
    
    .header-search-wrapper {
      max-width: 650px;
    }
  }

  /* ── Predictive Search Dropdown ── */
  .predictive-search-results {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.15);
    border-radius: 4px;
    box-shadow: 0 6px 24px rgba(0,0,0,0.10);
    z-index: 9999;
    max-height: 420px;
    overflow-y: auto;
  }

  .predictive-search-results.is-visible {
    display: block;
  }

  .predictive-search__section-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.4);
    padding: 12px 14px 6px;
    margin: 0;
  }

  .predictive-search__item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 14px;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: background 0.15s;
  }

  .predictive-search__item:hover,
  .predictive-search__item.is-selected {
    background: rgba(0,0,0,0.05);
  }

  .predictive-search__item-image {
    width: 44px;
    height: 44px;
    object-fit: cover;
    border-radius: 3px;
    flex-shrink: 0;
    border: 1px solid rgba(0,0,0,0.08);
  }

  .predictive-search__item-image-placeholder {
    width: 44px;
    height: 44px;
    border-radius: 3px;
    flex-shrink: 0;
    background: rgba(0,0,0,0.06);
  }

  .predictive-search__item-text {
    flex: 1;
    min-width: 0;
  }

  .predictive-search__item-title {
    font-size: 14px;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin: 0 0 2px;
  }

  .predictive-search__item-meta {
    font-size: 12px;
    color: rgba(0,0,0,0.5);
    margin: 0;
  }

  .predictive-search__query-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    font-size: 14px;
    transition: background 0.15s;
  }

  .predictive-search__query-item:hover,
  .predictive-search__query-item.is-selected {
    background: rgba(0,0,0,0.05);
  }

  .predictive-search__query-icon {
    opacity: 0.4;
    flex-shrink: 0;
  }

  .predictive-search__divider {
    height: 1px;
    background: rgba(0,0,0,0.08);
    margin: 4px 0;
  }

  .predictive-search__no-results {
    padding: 16px 14px;
    font-size: 14px;
    color: rgba(0,0,0,0.5);
    text-align: center;
  }

  .predictive-search__loading {
    padding: 16px 14px;
    font-size: 14px;
    color: rgba(0,0,0,0.4);
    text-align: center;
  }

  .predictive-search__view-all {
    display: block;
    text-align: center;
    padding: 10px 14px;
    font-size: 13px;
    font-weight: 600;
    color: inherit;
    text-decoration: none;
    border-top: 1px solid rgba(0,0,0,0.08);
    transition: background 0.15s;
  }

  .predictive-search__view-all:hover {
    background: rgba(0,0,0,0.04);
  }
{% endstyle %}

