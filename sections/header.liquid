<script>
(function () {
  'use strict';

  // ── Configuration ──────────────────────────────────────────────
  const DEBOUNCE_MS   = 200;   // ms to wait after last keystroke
  const MIN_CHARS     = 2;     // minimum characters before searching
  const MAX_PRODUCTS  = 4;     // max product results to show
  const MAX_QUERIES   = 4;     // max query suggestions to show
  const SEARCH_URL    = '{{ routes.search_url }}';

  // ── Money formatter ────────────────────────────────────────────
  const moneyFormatter = new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: '{{ cart.currency.iso_code | default: "USD" }}'
  });

  function formatMoney(cents) {
    return moneyFormatter.format(cents / 100);
  }

  // ── SVG icons ──────────────────────────────────────────────────
  const searchIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`;

  // ── Debounce helper ────────────────────────────────────────────
  function debounce(fn, delay) {
    let timer;
    return function (...args) {
      clearTimeout(timer);
      timer = setTimeout(() => fn.apply(this, args), delay);
    };
  }

  // ── Fetch predictive search results from Shopify API ──────────
  async function fetchPredictiveResults(query) {
    const params = new URLSearchParams({
      q: query,
      resources: JSON.stringify({
        type:    ['product', 'query'],
        limit:   Math.max(MAX_PRODUCTS, MAX_QUERIES),
        options: { unavailable_products: 'last', fields: 'title,product_type,variants.title,vendor' }
      }),
      section_id: 'predictive-search'  // not used but required by some versions
    });

    // Shopify Predictive Search API endpoint
    const url = `/search/suggest.json?q=${encodeURIComponent(query)}&resources[type]=product,query&resources[limit]=${Math.max(MAX_PRODUCTS, MAX_QUERIES)}&resources[options][unavailable_products]=last`;

    const response = await fetch(url, {
      headers: { 'Content-Type': 'application/json' }
    });

    if (!response.ok) throw new Error('Search request failed');
    return response.json();
  }

  // ── Build HTML for the dropdown ────────────────────────────────
  function buildResultsHTML(data, query) {
    const resources  = data.resources && data.resources.results ? data.resources.results : {};
    const queries    = (resources.queries  || []).slice(0, MAX_QUERIES);
    const products   = (resources.products || []).slice(0, MAX_PRODUCTS);

    if (!queries.length && !products.length) {
      return `<p class="predictive-search__no-results">No results for "<strong>${escapeHTML(query)}</strong>"</p>`;
    }

    let html = '';

    // Query suggestions
    if (queries.length) {
      html += `<p class="predictive-search__section-title">Suggestions</p>`;
      queries.forEach(q => {
        const url = `${SEARCH_URL}?q=${encodeURIComponent(q.text)}&type=product`;
        html += `
          <a href="${url}" class="predictive-search__query-item" role="option">
            <span class="predictive-search__query-icon">${searchIcon}</span>
            <span>${highlightMatch(q.styled_text || q.text, query)}</span>
          </a>`;
      });
    }

    // Products
    if (products.length) {
      if (queries.length) html += `<div class="predictive-search__divider"></div>`;
      html += `<p class="predictive-search__section-title">Products</p>`;

      products.forEach(product => {
        const imgHTML = product.featured_image && product.featured_image.url
          ? `<img src="${product.featured_image.url}&width=100" alt="${escapeHTML(product.title)}" class="predictive-search__item-image" width="44" height="44" loading="lazy">`
          : `<div class="predictive-search__item-image-placeholder"></div>`;

        const price = product.variants && product.variants[0]
          ? formatMoney(product.variants[0].price)
          : '';

        html += `
          <a href="${product.url}" class="predictive-search__item" role="option">
            ${imgHTML}
            <div class="predictive-search__item-text">
              <p class="predictive-search__item-title">${escapeHTML(product.title)}</p>
              ${price ? `<p class="predictive-search__item-meta">${price}</p>` : ''}
            </div>
          </a>`;
      });
    }

    // View all link
    const viewAllUrl = `${SEARCH_URL}?q=${encodeURIComponent(query)}&type=product`;
    html += `<a href="${viewAllUrl}" class="predictive-search__view-all">View all results for "<strong>${escapeHTML(query)}</strong>"</a>`;

    return html;
  }

  // ── Utility: escape HTML ───────────────────────────────────────
  function escapeHTML(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  // ── Utility: bold matching portion in suggestion text ─────────
  function highlightMatch(text, query) {
    // text may already contain <em> tags from Shopify; just return it
    if (text.includes('<em>') || text.includes('<strong>')) return text;
    const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    return text.replace(new RegExp(`(${escaped})`, 'gi'), '<strong>$1</strong>');
  }

  // ── Core controller for a single search input ─────────────────
  function initPredictiveSearch(input, dropdown) {
    let currentQuery = '';
    let selectedIndex = -1;
    let items = [];

    function getItems() {
      return Array.from(dropdown.querySelectorAll('[role="option"]'));
    }

    function openDropdown() {
      dropdown.classList.add('is-visible');
      input.setAttribute('aria-expanded', 'true');
    }

    function closeDropdown() {
      dropdown.classList.remove('is-visible');
      input.setAttribute('aria-expanded', 'false');
      selectedIndex = -1;
    }

    function setSelected(index) {
      items = getItems();
      items.forEach(el => el.classList.remove('is-selected'));
      if (index >= 0 && index < items.length) {
        items[index].classList.add('is-selected');
        items[index].scrollIntoView({ block: 'nearest' });
      }
      selectedIndex = index;
    }

    // Keyboard navigation
    input.addEventListener('keydown', (e) => {
      if (!dropdown.classList.contains('is-visible')) return;
      items = getItems();

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setSelected(Math.min(selectedIndex + 1, items.length - 1));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setSelected(Math.max(selectedIndex - 1, -1));
        if (selectedIndex === -1) input.focus();
      } else if (e.key === 'Enter' && selectedIndex >= 0) {
        e.preventDefault();
        items[selectedIndex].click();
      } else if (e.key === 'Escape') {
        closeDropdown();
        input.blur();
      }
    });

    // Main search handler
    const handleInput = debounce(async () => {
      const query = input.value.trim();
      if (query === currentQuery) return;
      currentQuery = query;

      if (query.length < MIN_CHARS) {
        closeDropdown();
        dropdown.innerHTML = '';
        return;
      }

      dropdown.innerHTML = `<p class="predictive-search__loading">Searching…</p>`;
      openDropdown();

      try {
        const data = await fetchPredictiveResults(query);
        if (input.value.trim() !== query) return; // stale response
        dropdown.innerHTML = buildResultsHTML(data, query);
        openDropdown();
      } catch (err) {
        dropdown.innerHTML = `<p class="predictive-search__no-results">Something went wrong. Please try again.</p>`;
      }
    }, DEBOUNCE_MS);

    input.addEventListener('input', handleInput);

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!input.closest('.header-search-wrapper').contains(e.target)) {
        closeDropdown();
      }
    });

    // Reopen on focus if there's a value
    input.addEventListener('focus', () => {
      if (input.value.trim().length >= MIN_CHARS && dropdown.innerHTML.trim()) {
        openDropdown();
      }
    });
  }

  // ── Attach to all search forms ─────────────────────────────────
  function init() {
    document.querySelectorAll('.predictive-search-form').forEach(form => {
      const input    = form.querySelector('.predictive-search-input');
      const dropdown = form.querySelector('.predictive-search-results');
      if (input && dropdown) {
        initPredictiveSearch(input, dropdown);
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

