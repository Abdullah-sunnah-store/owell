{{ 'section-account-auth.css' | asset_url | stylesheet_tag }}

<div class="owell-auth">
  <div class="owell-auth__container">

    {%- form 'create_customer', novalidate: 'novalidate' -%}

      <h1 class="owell-auth__title">Create an Account</h1>
      <p class="owell-auth__subtitle">Track orders, manage subscriptions, and streamline future purchases.</p>

      {%- if form.errors -%}
        <div class="owell-auth__error">
          {%- for field in form.errors -%}
            {%- if field == 'form' -%}
              {{ form.errors.messages[field] }}
            {%- else -%}
              {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}.
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="owell-auth__name-row">
        <div class="owell-auth__field">
          <label class="owell-auth__label" for="RegisterForm-FirstName">First Name</label>
          <input
            class="owell-auth__input"
            type="text"
            name="customer[first_name]"
            id="RegisterForm-FirstName"
            {% if form.first_name %}value="{{ form.first_name }}"{% endif %}
            autocomplete="given-name"
          >
        </div>
        <div class="owell-auth__field">
          <label class="owell-auth__label" for="RegisterForm-LastName">Last Name</label>
          <input
            class="owell-auth__input"
            type="text"
            name="customer[last_name]"
            id="RegisterForm-LastName"
            {% if form.last_name %}value="{{ form.last_name }}"{% endif %}
            autocomplete="family-name"
          >
        </div>
      </div>

      <div class="owell-auth__field">
        <label class="owell-auth__label" for="RegisterForm-email">Email</label>
        <input
          class="owell-auth__input{% if form.errors contains 'email' %} has-error{% endif %}"
          type="email"
          name="customer[email]"
          id="RegisterForm-email"
          {% if form.email %}value="{{ form.email }}"{% endif %}
          autocomplete="email"
          autocorrect="off"
          autocapitalize="off"
        >
      </div>

      <div class="owell-auth__field">
        <label class="owell-auth__label" for="RegisterForm-password">Password</label>
        <input
          class="owell-auth__input{% if form.errors contains 'password' %} has-error{% endif %}"
          type="password"
          name="customer[password]"
          id="RegisterForm-password"
          autocomplete="new-password"
        >
      </div>

      <button type="submit" class="owell-auth__btn-primary">Create Account</button>

    {%- endform -%}

    <div class="owell-auth__below-form">
      Already have an account? <a href="{{ routes.account_login_url }}">Log In</a>
    </div>
    <a href="{{ section.settings.business_account_url | default: '/pages/wholesale' }}" class="owell-auth__business-link">
        For structured pricing and volume purchasing: Open a Business Account →
      </a>
  </div>
</div>

{% schema %}
{
  "name": "Customer register",
  "settings": [],
  "enabled_on": {
    "templates": ["customers/register"]
  }
}
{% endschema %}
