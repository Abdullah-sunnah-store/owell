{% schema %}
{
  "name": "Featured collection",
  "tag": "section",
  "max_blocks": 5,
  "settings": [
    {
      "label": "Maximum products to show",
      "id": "max_product_show",
      "type": "range",
      "min": 1,
      "max": 25,
      "step": 1,
      "default": 5
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout",
      "options": [
        {
          "label": "Carousel",
          "value": "carousel"
        },
        {
          "label": "Grid",
          "value": "grid"
        }
      ],
      "default": "carousel"
    },
    {
      "type": "header",
      "content": "Grid settings"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Number of columns on desktop",
      "options": [
        {
          "label": "3",
          "value": "3"
        },
        {
          "label": "4",
          "value": "4"
        },
        {
          "label": "5",
          "value": "5"
        }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "label": "1",
          "value": "1"
        },
        {
          "label": "2",
          "value": "2"
        }
      ],
      "default": "1",
      "label": "Number of columns on mobile"
    },
    {
      "type": "header",
      "content": "Section content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "checkbox",
      "id": "use_outline_button",
      "label": "Use outline button style",
      "info": "This will work when product card buttton is stacked",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_view_all_button",
      "label": "Show link",
      "default": true
    },
    {
      "type": "select",
      "id": "view_all_link_style",
      "label": "Link style",
      "options": [
        {
          "value": "icon",
          "label": "Arrow"
        },
        {
          "value": "text",
          "label": "Text"
        }
      ],
      "default": "icon"
    },
    {
      "type": "select",
      "id": "view_all_link_position",
      "label": "Desktop link position",
      "options": [
        {
          "value": "start",
          "label": "Start"
        },
        {
          "value": "end",
          "label": "End"
        }
      ],
      "default": "start"
    },
    {
      "type": "text",
      "id": "view_all_link_text",
      "label": "Link text",
      "default": "View all",
      "info": "Will only work when link style is set to 'text' ",
      "placeholder": "Link text"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "select",
      "id": "link_target",
      "label": "Open link in",
      "options": [
        {
          "label": "New tab",
          "value": "_blank"
        },
        {
          "label": "Same tab",
          "value": "_top"
        }
      ],
      "default": "_top"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:settings_schema.global.section.padding.settings.padding_top.label",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:settings_schema.global.section.padding.settings.padding_bottom.label",
      "default": 52
    },
    {
      "type": "select",
      "id": "border_size",
      "label": "Border",
      "options": [
        {
          "label": "Hide",
          "value": "hide"
        },
        {
          "label": "Full width",
          "value": "full_width"
        },
        {
          "label": "Fixed width",
          "value": "fixed_width"
        }
      ],
      "default": "hide"
    },
    {
      "type": "select",
      "id": "border_position",
      "label": "Border position",
      "options": [
        {
          "label": "Both",
          "value": "both"
        },
        {
          "label": "Top",
          "value": "top"
        },
        {
          "label": "Bottom",
          "value": "bottom"
        }
      ],
      "default": "both"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "Color scheme"
    }
  ],
  "blocks": [
    {
      "name": "Collection",
      "type": "featured_collection",
      "settings": [
        {
          "type": "text",
          "id": "tab_heading",
          "label": "Heading",
          "default": "Collection",
          "info": "This will replace the collection heading if there are multiple blocks"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    },
    {
      "name": "Products",
      "type": "product_collection",
      "settings": [
        {
          "type": "text",
          "id": "tab_heading",
          "label": "Heading",
          "default": "Collection",
          "info": "This will shown as the tab heading if there are multiple blocks"
        },
        {
          "type": "product_list",
          "id": "products",
          "label": "Products"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured collection",
      "blocks": [
        {
          "type": "featured_collection",
          "settings": {
            "tab_heading": "Collection 1"
          }
        },
        {
          "type": "featured_collection",
          "settings": {
            "tab_heading": "Collection 2"
          }
        },
        {
          "type": "featured_collection",
          "settings": {
            "tab_heading": "Collection 3"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["*"]
  }
}
{% endschema %}
