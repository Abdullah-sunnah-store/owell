{% comment %}
  Owell Complete Section - Benefits, Tier Pricing & How It Works
  Designed for bulk purchasing and professional supplies
{% endcomment %}

<style>
  .owell-complete-section {
    background: #ffffff;
  }

  /* Benefits Section */
  .owell-benefits-wrapper {
    background: linear-gradient(135deg, #042436 0%, #0a3a52 100%);
    padding: 80px 20px;
    position: relative;
    overflow: hidden;
  }

  .owell-benefits-wrapper::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: 
      radial-gradient(circle at 20% 30%, rgba(86, 194, 179, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(80, 82, 197, 0.08) 0%, transparent 50%);
    pointer-events: none;
  }

  .owell-container {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .owell-section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .owell-badge {
    display: inline-block;
    background: rgba(86, 194, 179, 0.15);
    border: 1px solid rgba(86, 194, 179, 0.3);
    color: #56c2b3;
    padding: 8px 20px;
    border-radius: 30px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-bottom: 16px;
    text-transform: uppercase;
  }

  .owell-section-title {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 800;
    color: #ffffff;
    margin: 0 0 16px 0;
    letter-spacing: -0.5px;
  }

  .owell-section-subtitle {
    font-size: clamp(16px, 2vw, 20px);
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Benefits Grid */
  .owell-benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
  }

  .owell-benefit-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 40px 32px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .owell-benefit-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #56c2b3, #5052c5);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.6s ease;
  }

  .owell-benefit-card:hover::before {
    transform: scaleX(1);
  }

  .owell-benefit-card:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(86, 194, 179, 0.3);
    transform: translateY(-5px);
  }

  .owell-benefit-icon {
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, #56c2b3, #5052c5);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    margin-bottom: 24px;
  }

  .owell-benefit-title {
    font-size: 22px;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 12px 0;
  }

  .owell-benefit-description {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.7;
    margin: 0;
  }

  /* Tier Pricing Section */
  .owell-pricing-wrapper {
    padding: 80px 20px;
    background: #f9fafb;
  }

  .owell-pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin-top: 50px;
  }

  .owell-pricing-card {
    background: #ffffff;
    border: 2px solid #e5e7eb;
    border-radius: 20px;
    padding: 36px 28px;
    transition: all 0.3s ease;
    position: relative;
  }

  .owell-pricing-card.featured {
    border-color: #56c2b3;
    box-shadow: 0 10px 40px rgba(86, 194, 179, 0.15);
    transform: scale(1.05);
  }

  .owell-pricing-card.featured .owell-pricing-badge {
    display: block;
  }

  .owell-pricing-card:hover {
    border-color: #56c2b3;
    box-shadow: 0 10px 30px rgba(86, 194, 179, 0.2);
    transform: translateY(-5px);
  }

  .owell-pricing-card.featured:hover {
    transform: scale(1.05) translateY(-5px);
  }

  .owell-pricing-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, #56c2b3, #5052c5);
    color: #ffffff;
    padding: 6px 20px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: none;
  }

  .owell-pricing-tier {
    font-size: 14px;
    font-weight: 600;
    color: #56c2b3;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
  }

  .owell-pricing-title {
    font-size: 24px;
    font-weight: 800;
    color: #042436;
    margin: 0 0 8px 0;
  }

  .owell-pricing-quantity {
    font-size: 14px;
    color: #6b7280;
    margin-bottom: 20px;
  }

  .owell-pricing-amount {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 8px;
  }

  .owell-pricing-price {
    font-size: 42px;
    font-weight: 800;
    color: #042436;
    line-height: 1;
  }

  .owell-pricing-unit {
    font-size: 16px;
    color: #6b7280;
    font-weight: 500;
  }

  .owell-pricing-save {
    background: rgba(86, 194, 179, 0.1);
    color: #56c2b3;
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 13px;
    font-weight: 700;
    display: inline-block;
    margin-bottom: 24px;
  }

  .owell-pricing-features {
    list-style: none;
    padding: 0;
    margin: 0 0 28px 0;
  }

  .owell-pricing-features li {
    padding: 10px 0;
    color: #374151;
    font-size: 15px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .owell-pricing-features li::before {
    content: '✓';
    width: 20px;
    height: 20px;
    background: rgba(86, 194, 179, 0.15);
    color: #56c2b3;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .owell-pricing-button {
    width: 100%;
    padding: 14px 24px;
    background: linear-gradient(135deg, #56c2b3, #5052c5);
    color: #ffffff;
    border: none;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    text-decoration: none;
    display: block;
  }

  .owell-pricing-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(86, 194, 179, 0.3);
  }

  .owell-pricing-button.secondary {
    background: #ffffff;
    color: #56c2b3;
    border: 2px solid #56c2b3;
  }

  .owell-pricing-button.secondary:hover {
    background: #56c2b3;
    color: #ffffff;
  }

  /* How It Works Section */
  .owell-how-wrapper {
    padding: 80px 20px;
    background: linear-gradient(135deg, #042436 0%, #0a3a52 100%);
    position: relative;
    overflow: hidden;
  }

  .owell-how-wrapper::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: 
      radial-gradient(circle at 30% 50%, rgba(80, 82, 197, 0.08) 0%, transparent 50%),
      radial-gradient(circle at 70% 50%, rgba(86, 194, 179, 0.1) 0%, transparent 50%);
    pointer-events: none;
  }

  .owell-steps-container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .owell-steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 40px;
    margin-top: 60px;
    position: relative;
  }

  /* Connection Line */
  .owell-steps-grid::before {
    content: '';
    position: absolute;
    top: 40px;
    left: 10%;
    right: 10%;
    height: 2px;
    background: linear-gradient(90deg, 
      rgba(86, 194, 179, 0.3) 0%, 
      rgba(86, 194, 179, 0.6) 50%, 
      rgba(86, 194, 179, 0.3) 100%);
    z-index: 0;
  }

  .owell-step-card {
    position: relative;
    text-align: center;
    z-index: 1;
  }

  .owell-step-number {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, #56c2b3, #5052c5);
    border: 4px solid #042436;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    font-weight: 800;
    color: #ffffff;
    margin: 0 auto 24px auto;
    box-shadow: 0 8px 24px rgba(86, 194, 179, 0.3);
    position: relative;
    z-index: 2;
  }

  .owell-step-title {
    font-size: 22px;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 12px 0;
  }

  .owell-step-description {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    margin: 0;
  }

  /* Final CTA */
  .owell-final-cta {
    background: linear-gradient(135deg, rgba(86, 194, 179, 0.15), rgba(80, 82, 197, 0.1));
    border: 2px solid rgba(86, 194, 179, 0.3);
    border-radius: 24px;
    padding: 50px 40px;
    text-align: center;
    margin-top: 60px;
  }

  .owell-final-cta-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    color: #ffffff;
    margin: 0 0 16px 0;
  }

  .owell-final-cta-text {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 0 32px 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .owell-final-cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .owell-final-button {
    padding: 16px 40px;
    border-radius: 12px;
    font-size: 18px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .owell-final-button.primary {
    background: linear-gradient(135deg, #56c2b3, #5052c5);
    color: #ffffff;
    box-shadow: 0 10px 30px rgba(86, 194, 179, 0.3);
  }

  .owell-final-button.primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 40px rgba(86, 194, 179, 0.4);
  }

  .owell-final-button.secondary {
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
    border: 2px solid rgba(255, 255, 255, 0.3);
  }

  .owell-final-button.secondary:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: #56c2b3;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .owell-benefits-wrapper,
    .owell-pricing-wrapper,
    .owell-how-wrapper {
      padding: 60px 20px;
    }

    .owell-benefits-grid,
    .owell-pricing-grid {
      grid-template-columns: 1fr;
    }

    .owell-pricing-card.featured {
      transform: scale(1);
    }

    .owell-pricing-card.featured:hover {
      transform: translateY(-5px);
    }

    .owell-steps-grid::before {
      display: none;
    }

    .owell-final-cta-buttons {
      flex-direction: column;
      align-items: stretch;
    }

    .owell-final-button {
      width: 100%;
      text-align: center;
    }
  }
</style>

<div class="owell-complete-section">

  <!-- BENEFITS SECTION -->
  <section class="owell-benefits-wrapper">
    <div class="owell-container">
      <div class="owell-section-header">
        <div class="owell-badge">{{ section.settings.benefits_badge }}</div>
        <h2 class="owell-section-title">{{ section.settings.benefits_title }}</h2>
        <p class="owell-section-subtitle">{{ section.settings.benefits_subtitle }}</p>
      </div>

      <div class="owell-benefits-grid">
        {% for i in (1..4) %}
          {% assign icon_key = 'benefit_' | append: i | append: '_icon' %}
          {% assign title_key = 'benefit_' | append: i | append: '_title' %}
          {% assign desc_key = 'benefit_' | append: i | append: '_description' %}
          
          <div class="owell-benefit-card">
            <div class="owell-benefit-icon">{{ section.settings[icon_key] }}</div>
            <h3 class="owell-benefit-title">{{ section.settings[title_key] }}</h3>
            <p class="owell-benefit-description">{{ section.settings[desc_key] }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- TIER PRICING SECTION -->
  <section class="owell-pricing-wrapper">
    <div class="owell-container">
      <div class="owell-section-header">
        <div class="owell-badge" style="background: rgba(86, 194, 179, 0.1); border-color: #56c2b3;">{{ section.settings.pricing_badge }}</div>
        <h2 class="owell-section-title" style="color: #042436;">{{ section.settings.pricing_title }}</h2>
        <p class="owell-section-subtitle" style="color: #6b7280;">{{ section.settings.pricing_subtitle }}</p>
      </div>

      <div class="owell-pricing-grid">
        {% for i in (1..4) %}
          {% assign tier_key = 'tier_' | append: i | append: '_name' %}
          {% assign qty_key = 'tier_' | append: i | append: '_quantity' %}
          {% assign price_key = 'tier_' | append: i | append: '_price' %}
          {% assign unit_key = 'tier_' | append: i | append: '_unit' %}
          {% assign save_key = 'tier_' | append: i | append: '_save' %}
          {% assign features_key = 'tier_' | append: i | append: '_features' %}
          {% assign featured_key = 'tier_' | append: i | append: '_featured' %}
          {% assign button_text_key = 'tier_' | append: i | append: '_button' %}
          {% assign button_link_key = 'tier_' | append: i | append: '_link' %}
          
          <div class="owell-pricing-card {% if section.settings[featured_key] %}featured{% endif %}">
            <div class="owell-pricing-badge">Most Popular</div>
            <div class="owell-pricing-tier">{{ section.settings[tier_key] }}</div>
            <h3 class="owell-pricing-title">{{ section.settings[qty_key] }}</h3>
            <div class="owell-pricing-amount">
              <span class="owell-pricing-price">{{ section.settings[price_key] }}</span>
              <span class="owell-pricing-unit">{{ section.settings[unit_key] }}</span>
            </div>
            {% if section.settings[save_key] != blank %}
              <div class="owell-pricing-save">{{ section.settings[save_key] }}</div>
            {% endif %}
            <ul class="owell-pricing-features">
              {% assign features = section.settings[features_key] | newline_to_br | split: '<br />' %}
              {% for feature in features %}
                {% if feature != blank %}
                  <li>{{ feature }}</li>
                {% endif %}
              {% endfor %}
            </ul>
            <a href="{{ section.settings[button_link_key] }}" 
               class="owell-pricing-button {% unless section.settings[featured_key] %}secondary{% endunless %}">
              {{ section.settings[button_text_key] }}
            </a>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS SECTION -->
  <section class="owell-how-wrapper">
    <div class="owell-steps-container">
      <div class="owell-section-header">
        <div class="owell-badge">{{ section.settings.how_badge }}</div>
        <h2 class="owell-section-title">{{ section.settings.how_title }}</h2>
        <p class="owell-section-subtitle">{{ section.settings.how_subtitle }}</p>
      </div>

      <div class="owell-steps-grid">
        {% for i in (1..4) %}
          {% assign step_title_key = 'step_' | append: i | append: '_title' %}
          {% assign step_desc_key = 'step_' | append: i | append: '_description' %}
          
          <div class="owell-step-card">
            <div class="owell-step-number">{{ i }}</div>
            <h3 class="owell-step-title">{{ section.settings[step_title_key] }}</h3>
            <p class="owell-step-description">{{ section.settings[step_desc_key] }}</p>
          </div>
        {% endfor %}
      </div>

      <div class="owell-final-cta">
        <h3 class="owell-final-cta-title">{{ section.settings.final_cta_title }}</h3>
        <p class="owell-final-cta-text">{{ section.settings.final_cta_text }}</p>
        <div class="owell-final-cta-buttons">
          <a href="{{ section.settings.final_button_1_link }}" class="owell-final-button primary">
            {{ section.settings.final_button_1_text }}
          </a>
          <a href="{{ section.settings.final_button_2_link }}" class="owell-final-button secondary">
            {{ section.settings.final_button_2_text }}
          </a>
        </div>
      </div>
    </div>
  </section>

</div>

