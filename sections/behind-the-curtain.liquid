<script>
(function() {
  const sectionId = '{{ section.id }}';
  const galleryTrack = document.querySelector(`.btc-gallery-track-${sectionId}`);
  
  if (!galleryTrack) return;
  
  const scrollSpeed = parseFloat(galleryTrack.getAttribute('data-speed')) || 0.7;
  const direction = galleryTrack.getAttribute('data-direction') || 'left';
  const pauseOnHover = galleryTrack.getAttribute('data-pause-hover') === 'true';
  
  // Apply custom widths
  document.querySelectorAll(`.btc-column-${sectionId}[data-column-type="custom"]`).forEach(column => {
    const customWidth = column.getAttribute('data-custom-width');
    if (customWidth) {
      column.style.width = customWidth + 'px';
    }
  });
  
  // Apply custom heights
  document.querySelectorAll(`.btc-image-wrapper-${sectionId}`).forEach(wrapper => {
    const customHeight = wrapper.getAttribute('data-height');
    if (customHeight) {
      wrapper.style.height = customHeight + 'px';
    }
  });
  
  // Calculate dimensions
  const columns = Array.from(document.querySelectorAll(`.btc-column-${sectionId}`));
  const originalColumnCount = columns.length / 3; // Divided by 3 because we render 3 sets
  
  let totalWidth = 0;
  for (let i = 0; i < originalColumnCount; i++) {
    const column = columns[i];
    const columnWidth = column.offsetWidth;
    const marginLeft = parseFloat(getComputedStyle(column).marginLeft);
    const marginRight = parseFloat(getComputedStyle(column).marginRight);
    totalWidth += columnWidth + marginLeft + marginRight;
  }
  
  const resetPoint = totalWidth;
  
  let scrollPosition = 0;
  let animationId;
  let isPaused = false;
  
  function animate() {
    if (!isPaused) {
      if (direction === 'left') {
        scrollPosition += scrollSpeed;
        if (scrollPosition >= resetPoint) {
          scrollPosition = 0;
        }
        galleryTrack.style.transform = `translateX(${-scrollPosition}px)`;
      } else {
        scrollPosition -= scrollSpeed;
        if (scrollPosition <= -resetPoint) {
          scrollPosition = 0;
        }
        galleryTrack.style.transform = `translateX(${scrollPosition}px)`;
      }
    }
    
    animationId = requestAnimationFrame(animate);
  }
  
  // Start animation
  animate();
  
  // Pause on hover
  if (pauseOnHover) {
    galleryTrack.addEventListener('mouseenter', () => {
      isPaused = true;
    });
    
    galleryTrack.addEventListener('mouseleave', () => {
      isPaused = false;
    });
  }
  
  // Handle window resize
  let resizeTimeout;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      // Recalculate on resize if needed
      scrollPosition = 0;
    }, 250);
  });
  
  // Clean up
  window.addEventListener('pagehide', () => {
    if (animationId) {
      cancelAnimationFrame(animationId);
    }
  });
})();
</script>
