{{ 'section-footer-enterprise.css' | asset_url | stylesheet_tag }}
<script defer="defer" src="{{ 'localization.js' | asset_url }}"></script>

{% liquid
  assign enable_follow_on_shop = section.settings.enable_follow_on_shop
%}

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 | append: 'px' }};
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 | append: 'px' }};
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | append: 'px' }};
      padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
    }
  }
{% endstyle %}

{%- comment -%} ── ENTERPRISE CTA STRIP ── {%- endcomment -%}
{% if section.settings.show_cta_strip %}
  <section class="owell-cta-strip">
    <div class="container">
      <div class="owell-cta-strip__inner">
        {% if section.settings.cta_headline != blank %}
          <h2 class="owell-cta-strip__headline">{{ section.settings.cta_headline }}</h2>
        {% endif %}
        {% if section.settings.cta_subtext != blank %}
          <p class="owell-cta-strip__subtext">{{ section.settings.cta_subtext }}</p>
        {% endif %}
        {% if section.settings.cta_btn1_text != blank or section.settings.cta_btn2_text != blank %}
          <div class="owell-cta-strip__buttons">
            {% if section.settings.cta_btn1_text != blank %}
              <a
                href="{{ section.settings.cta_btn1_url | default: routes.root_url }}"
                class="owell-cta-btn"
              >
                {{- section.settings.cta_btn1_text -}}
              </a>
            {% endif %}
            {% if section.settings.cta_btn2_text != blank %}
              <a
                href="{{ section.settings.cta_btn2_url | default: routes.root_url }}"
                class="owell-cta-btn"
              >
                {{- section.settings.cta_btn2_text -}}
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </section>
{% endif %}

{%- comment -%} ── MAIN FOOTER ── {%- endcomment -%}
<footer
  class="owell-footer section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}"
  role="contentinfo"
>
  <div class="container">

    {%- comment -%} ── 5-COLUMN GRID ── {%- endcomment -%}
    <div class="owell-footer__grid">

      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop Start {%- endcomment -%}
          {%- capture hide_resource -%}{% render "orbit_wholesale_product_visibility", resource: block %}{%- endcapture -%}
          {%- if hide_resource == "true" -%}{% continue %}{%- endif -%}
          {%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop End {%- endcomment -%}

          {% case block.type %}

            {%- comment -%} ── BRAND COLUMN ── {%- endcomment -%}
            {% when 'brand' %}
              <div
                class="owell-footer__col owell-footer__col--brand"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.footer_logo -%}
                  {%- capture widths -%}
                    {{ block.settings.image_width }},{{ block.settings.image_width | times: 2 | at_most: block.settings.footer_logo.width }}
                  {%- endcapture -%}
                  <div
                    class="owell-footer__logo"
                    style="--footer-logo-width: {{ block.settings.image_width | append: 'px' }}"
                  >
                    <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
                      {{
                        block.settings.footer_logo
                        | image_url: width: block.settings.footer_logo.width
                        | image_tag:
                          loading: 'lazy',
                          widths: widths,
                          class: 'image',
                          aria-label: shop.name
                      }}
                    </a>
                  </div>
                {%- endif -%}

                {%- comment -%} Tagline — dedicated setting, falls back to heading {%- endcomment -%}
                {%- assign tagline_text = block.settings.tagline | default: block.settings.heading -%}
                {%- if tagline_text != blank -%}
                  <p class="owell-footer__tagline">{{ tagline_text }}</p>
                {%- endif -%}

                {%- comment -%} Descriptor — dedicated setting, falls back to content {%- endcomment -%}
                {%- assign descriptor_text = block.settings.descriptor -%}
                {%- if descriptor_text != blank -%}
                  <p class="owell-footer__descriptor">{{ descriptor_text }}</p>
                {%- elsif block.settings.content != blank -%}
                  <div class="owell-footer__descriptor RTE-content">{{ block.settings.content }}</div>
                {%- endif -%}

                {%- if block.settings.trust_row != blank -%}
                  <div class="owell-footer__trust">{{ block.settings.trust_row }}</div>
                {%- endif -%}

                {%- if block.settings.brand_social_media_icons -%}
                  <div class="owell-footer__social">
                    {% render 'social-media-icons' %}
                  </div>
                {%- endif -%}
              </div>

            {%- comment -%} ── MENU COLUMN ── {%- endcomment -%}
            {% when 'menu' %}
              {%- assign col_heading = '' -%}
              {%- if block.settings.show_menu_title and block.settings.menu.title != blank -%}
                {%- assign col_heading = block.settings.menu.title -%}
              {%- elsif block.settings.heading != blank -%}
                {%- assign col_heading = block.settings.heading -%}
              {%- endif -%}

              <div class="owell-footer__col" {{ block.shopify_attributes }}>

                {%- comment -%} Desktop view {%- endcomment -%}
                <div class="tab-only">
                  {%- if col_heading != blank -%}
                    <h3 class="owell-footer__col-title">{{ col_heading }}</h3>
                  {%- endif -%}
                  {%- if block.settings.menu != blank -%}
                    <ul class="owell-footer__links" role="list" aria-label="{{ col_heading }}">
                      {%- for link in block.settings.menu.links -%}
                        {%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop Start {%- endcomment -%}
                        {%- capture hide_resource -%}{% render "orbit_wholesale_product_visibility", resource: link %}{%- endcapture -%}
                        {%- if hide_resource == "true" -%}{% continue %}{%- endif -%}
                        {%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop End {%- endcomment -%}
                        <li>
                          <a
                            href="{{ link.url }}"
                            class="owell-footer__link{% if link.active %} active{% endif %}"
                            aria-label="{{ link.title }}"
                          >
                            {{- link.title -}}
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>

                {%- comment -%} Mobile accordion {%- endcomment -%}
                <div class="mobile-sm-only">
                  <accordion-tab breakpoint_match="768px">
                    <details
                      accordionTab
                      aria-expanded="false"
                      class="owell-footer__accordion"
                      {{ block.shopify_attributes }}
                    >
                      <summary class="owell-footer__accordion-head">
                        {%- if col_heading != blank -%}
                          <h3 class="owell-footer__col-title">{{ col_heading }}</h3>
                        {%- endif -%}
                      </summary>
                      <div accordionBody class="owell-footer__accordion-body">
                        {%- if block.settings.menu != blank -%}
                          <ul class="owell-footer__links" role="list">
                            {%- for link in block.settings.menu.links -%}
                              {%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop Start {%- endcomment -%}
                              {%- capture hide_resource -%}{% render "orbit_wholesale_product_visibility", resource: link %}{%- endcapture -%}
                              {%- if hide_resource == "true" -%}{% continue %}{%- endif -%}
                              {%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop End {%- endcomment -%}
                              <li>
                                <a
                                  href="{{ link.url }}"
                                  class="owell-footer__link{% if link.active %} active{% endif %}"
                                >
                                  {{- link.title -}}
                                </a>
                              </li>
                            {%- endfor -%}
                          </ul>
                        {%- endif -%}
                      </div>
                    </details>
                  </accordion-tab>
                </div>

              </div>

            {%- comment -%} ── TEXT BLOCK ── {%- endcomment -%}
            {% when 'text' %}
              <div class="owell-footer__col" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3 class="owell-footer__col-title">{{ block.settings.heading }}</h3>
                {%- endif -%}
                {%- if block.settings.subText -%}
                  <div class="owell-footer__text-content RTE-content">{{ block.settings.subText }}</div>
                {%- endif -%}
              </div>

            {%- comment -%} ── NEWSLETTER BLOCK (minimal, non-dominant) ── {%- endcomment -%}
            {% when 'newsletter' %}
              <div class="owell-footer__col owell-footer__col--newsletter" {{ block.shopify_attributes }}>
                {%- if block.settings.newsletter_header != blank -%}
                  <h3 class="owell-footer__col-title">{{ block.settings.newsletter_header }}</h3>
                {%- endif -%}
                {%- if block.settings.newsletter_subtext -%}
                  <div class="owell-footer__text-content">{{ block.settings.newsletter_subtext }}</div>
                {%- endif -%}
                {%- form 'customer', id: 'ContactFooter' -%}
                  <div class="owell-newsletter">
                    <input name="contact[tags]" type="hidden" value="newsletter">
                    <div class="owell-newsletter__group">
                      <label for="newsletterForm--{{ section.id }}" class="visually-hidden">
                        {{ 'newsletter.label' | t }}
                      </label>
                      <input
                        id="newsletterForm--{{ section.id }}"
                        type="email"
                        name="contact[email]"
                        class="owell-newsletter__input"
                        placeholder="{{ 'newsletter.label' | t }}"
                        value="{{ form.email }}"
                        aria-required="true"
                        autocorrect="off"
                        autocapitalize="off"
                        autocomplete="email"
                        {% if form.errors %}
                          autofocus
                          aria-invalid="true"
                          aria-describedby="ContactFooter-error"
                        {% endif %}
                        required
                      >
                      <button
                        class="owell-newsletter__btn"
                        name="commit"
                        type="submit"
                        aria-label="{{ 'newsletter.button_label' | t }}"
                      >
                        {{- 'newsletter.button_label' | t -}}
                      </button>
                    </div>
                    {%- if form.posted_successfully? -%}
                      <p class="owell-newsletter__success">{{ 'newsletter.success' | t }}</p>
                    {%- endif -%}
                    {%- if form.errors -%}
                      <p class="owell-newsletter__success" style="color:#ff6b6b;">
                        {{ form.errors.messages.form }}
                      </p>
                    {%- endif -%}
                  </div>
                {%- endform -%}
              </div>

          {% endcase %}
        {% endfor %}
      {% endif %}

    </div>
    {%- comment -%} /.owell-footer__grid {%- endcomment -%}

    {%- comment -%} ── BOTTOM CONTACT STRIP ── {%- endcomment -%}
    

    {%- comment -%} ── SUPPLEMENTAL: LOCALIZATION + PAYMENT + FOLLOW ── {%- endcomment -%}
    {%- assign show_localization = false -%}
    {%- if section.settings.show_country_selector and localization.available_countries.size > 1 -%}
      {%- assign show_localization = true -%}
    {%- endif -%}
    {%- if section.settings.show_locale_selector and localization.available_languages.size > 1 -%}
      {%- assign show_localization = true -%}
    {%- endif -%}

    {%- if show_localization or section.settings.payment_enable or enable_follow_on_shop -%}
      <div class="owell-footer__supplemental">

        <div class="owell-footer__localization">
          {% if section.settings.show_country_selector and localization.available_countries.size > 1 %}
            <div aria-label="Country Selector" class="footer__country localization-dropdown country-selector">
              <localization-component>
                {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
                  <button
                    class="localization-dropdown__btn"
                    localization-btn-label
                    aria-expanded="false"
                    type="button"
                  >
                    {%- if section.settings.show_country_flag -%}
                      <link
                        href="{{ 'section-country-selector.css' | asset_url }}"
                        rel="stylesheet"
                        media="print"
                        onload="this.media='all'"
                      >
                      <span class="country-flags country-flags--{{ localization.country.iso_code }}"></span>
                    {%- endif -%}
                    {% if section.settings.show_country_name %}
                      <span>{{ localization.country.name }}</span>
                    {% endif %}
                    ({{ localization.country.currency.iso_code }}
                    {{ localization.country.currency.symbol }})
                    {% render 'icon' with 'caret' %}
                  </button>
                  <ul class="localization-dropdown__list" hidden localization-dropdown-panel>
                    {% for country in localization.available_countries %}
                      {%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop Start {%- endcomment -%}
                      {%- capture hide_resource -%}{% render "orbit_wholesale_product_visibility", resource: country %}{%- endcapture -%}
                      {%- if hide_resource == "true" -%}{% continue %}{%- endif -%}
                      {%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop End {%- endcomment -%}
                      <li class="localization-dropdown__item">
                        <a
                          class="localization-dropdown__item-link"
                          data-value="{{ country.iso_code }}"
                          href="#"
                          {% if country.iso_code == localization.country.iso_code %}active-link{% endif %}
                          localization-link
                        >
                          {%- if section.settings.show_country_flag -%}
                            <span class="country-flags country-flags--{{ country.iso_code }}"></span>
                          {%- endif -%}
                          <span>{{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})</span>
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                  <input name="country_code" type="hidden" value="{{ localization.country.iso_code }}">
                {%- endform -%}
              </localization-component>
            </div>
          {% endif %}

          {% if section.settings.show_locale_selector and localization.available_languages.size > 1 %}
            <div aria-label="Language Selector" class="footer__language localization-dropdown">
              <localization-component>
                {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
                  <button
                    class="localization-dropdown__btn"
                    localization-btn-label
                    aria-expanded="false"
                    type="button"
                  >
                    {{ localization.language.endonym_name | capitalize }}
                    {% render 'icon' with 'caret' %}
                  </button>
                  <ul class="localization-dropdown__list" hidden localization-dropdown-panel>
                    {% for language in localization.available_languages %}
                      {%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop Start {%- endcomment -%}
                      {%- capture hide_resource -%}{% render "orbit_wholesale_product_visibility", resource: language %}{%- endcapture -%}
                      {%- if hide_resource == "true" -%}{% continue %}{%- endif -%}
                      {%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop End {%- endcomment -%}
                      <li class="localization-dropdown__item">
                        <a
                          class="localization-dropdown__item-link"
                          data-value="{{ language.iso_code }}"
                          {% if language.iso_code == localization.language.iso_code %}active-link{% endif %}
                          href="#"
                          localization-link
                        >
                          {{- language.endonym_name | capitalize -}}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                  <input name="locale_code" type="hidden" value="{{ localization.language.iso_code }}">
                {%- endform -%}
              </localization-component>
            </div>
          {% endif %}

          {%- if enable_follow_on_shop -%}
            <div class="owell-footer__followshop" aria-label="Follow Our Shop">
              {{ shop | login_button: action: 'follow' }}
            </div>
          {%- endif -%}
        </div>
<div class="owell-footer__bottom">
      <div class="owell-footer__bottom-left">
        <span>
          All rights reserved.
          &copy; {{ 'now' | date: '%Y' }}
          {% if section.settings.copyright_entity != blank %}
            {{ section.settings.copyright_entity }}.
          {% else %}
            {{ shop.name | link_to: routes.root_url, class: 'owell-footer__shop-link' }}.
          {% endif %}
          
        </span>
        {% if section.settings.powered_by_enable %}
          <span class="owell-footer__poweredby">{{ powered_by_link }}</span>
        {% endif %}
      </div>

      <div class="owell-footer__bottom-right">
        {% if section.settings.footer_address != blank %}
          <span>{{ section.settings.footer_address }}</span>
        {% endif %}
        {% if section.settings.footer_phone != blank %}
          <a href="tel:{{ section.settings.footer_phone | remove: ' ' | remove: '.' | remove: '-' | remove: '(' | remove: ')' }}">
            {{- section.settings.footer_phone -}}
          </a>
        {% endif %}
        {% if section.settings.footer_email != blank %}
          <a href="mailto:{{ section.settings.footer_email }}">
            {{- section.settings.footer_email -}}
          </a>
        {% endif %}
      </div>
    </div>
        {%- if section.settings.payment_enable -%}
          <div class="owell-footer__payment">
            <ul class="list list-payment" role="list" aria-label="Accepted Payment Methods">
              {%- for type in shop.enabled_payment_types -%}
                {%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop Start {%- endcomment -%}
                {%- capture hide_resource -%}{% render "orbit_wholesale_product_visibility", resource: type %}{%- endcapture -%}
                {%- if hide_resource == "true" -%}{% continue %}{%- endif -%}
                {%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop End {%- endcomment -%}
                <li class="list-payment__item">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

      </div>
    {%- endif -%}

  </div>
</footer>

{% schema %}
{
  "name": "OWELL® Enterprise Footer",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "brand",
      "name": "Brand Authority",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "footer_logo",
          "label": "Logo",
          "info": "White/light logo recommended on dark background. 600×600px PNG."
        },
        {
          "type": "range",
          "id": "image_width",
          "min": 50,
          "max": 220,
          "step": 5,
          "unit": "px",
          "label": "Logo width",
          "default": 120
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "default": "Quality & Reliability You Can Count On",
          "info": "Short brand promise beneath the logo"
        },
        {
          "type": "text",
          "id": "descriptor",
          "label": "Brand descriptor",
          "default": "Brand-direct manufacturer of professional-grade essentials.",
          "info": "1–2 sentence brand description"
        },
        {
          "type": "text",
          "id": "trust_row",
          "label": "Trust row",
          "default": "1M+ Orders Delivered  |  Established 2016  |  Direct Manufacturing Partnerships  |  Same-Day Shipping",
          "info": "Use | to separate trust statements"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading (legacy)",
          "info": "Used only if Tagline is empty"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content (legacy)",
          "default": "<p>Write information about your brand and vision.</p>",
          "info": "Used only if Brand descriptor is empty"
        },
        {
          "type": "checkbox",
          "id": "brand_social_media_icons",
          "label": "Show social media icons",
          "default": true,
          "info": "Configure in [theme settings](/editor?context=theme&category=social%20media)"
        }
      ]
    },
    {
      "type": "menu",
      "name": "Navigation Column",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_menu_title",
          "label": "Use menu name as heading",
          "default": true
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Custom heading",
          "info": "Overrides menu name when set"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "info": "Dropdown items will not appear."
        }
      ]
    },
    {
      "type": "text",
      "name": "Text Block",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "richtext",
          "id": "subText",
          "label": "Content",
          "default": "<p>Text related to heading.</p>"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Email Signup",
      "settings": [
        {
          "type": "text",
          "id": "newsletter_header",
          "label": "Heading",
          "default": "Stay Informed"
        },
        {
          "type": "richtext",
          "id": "newsletter_subtext",
          "label": "Subtext",
          "default": "<p>Product launches, restock alerts, and industry updates.</p>"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Enterprise CTA Strip"
    },
    {
      "type": "checkbox",
      "id": "show_cta_strip",
      "label": "Show CTA strip above footer",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_headline",
      "label": "CTA headline",
      "default": "Supply Without Disruption."
    },
    {
      "type": "text",
      "id": "cta_subtext",
      "label": "CTA subtext",
      "default": "Professional-grade products. Predictable pricing. Controlled inventory."
    },
    {
      "type": "text",
      "id": "cta_btn1_text",
      "label": "Button 1 label",
      "default": "Open a Business Account"
    },
    {
      "type": "url",
      "id": "cta_btn1_url",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "cta_btn2_text",
      "label": "Button 2 label",
      "default": "Shop Products"
    },
    {
      "type": "url",
      "id": "cta_btn2_url",
      "label": "Button 2 link"
    },
    {
      "type": "header",
      "content": "Contact & Copyright"
    },
    {
      "type": "text",
      "id": "copyright_entity",
      "label": "Copyright entity",
      "default": "OWELL LLC",
      "info": "Appears as: © 2026 [entity]. All rights reserved."
    },
    {
      "type": "text",
      "id": "footer_address",
      "label": "Address",
      "default": "Freehold, NJ 07728"
    },
    {
      "type": "text",
      "id": "footer_phone",
      "label": "Phone number",
      "default": "212.227.9355"
    },
    {
      "type": "text",
      "id": "footer_email",
      "label": "Email address",
      "default": "info@owell.com"
    },
    {
      "type": "checkbox",
      "id": "powered_by_enable",
      "label": "Show 'Powered by Shopify'",
      "default": false
    },
    {
      "type": "header",
      "content": "Language selector",
      "info": "To add a language, go to your [language settings.](/admin/settings/languages)"
    },
    {
      "type": "checkbox",
      "id": "show_locale_selector",
      "label": "Show language selector",
      "default": true
    },
    {
      "type": "header",
      "content": "Country/region selector",
      "info": "To add a country/region, go to your [markets settings.](/admin/settings/markets)"
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "Enable country/region selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_country_flag",
      "label": "Show country flag",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_country_name",
      "label": "Show country name",
      "default": false
    },
    {
      "type": "header",
      "content": "Payment types"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "label": "Show payment icons",
      "default": true,
      "info": "Icons are set in [payment settings.](/admin/settings/payments)"
    },
    {
      "type": "header",
