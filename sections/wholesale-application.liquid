{{ 'section-wholesale-application.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 | append: 'px' }};
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 | append: 'px' }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | append: 'px' }};
      padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
    }
  }
{%- endstyle -%}

<section
  class="wholesale-application section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}"
  aria-label="{{ section.settings.heading }}"
>
  {%- form 'contact', id: 'WholesaleApplicationForm', class: 'wholesale-application__form' -%}
    <input type="hidden" name="contact[Form Type]" value="Wholesale Application">

    {%- if form.posted_successfully? -%}
      <script>
        try { localStorage.setItem('owell_b2b_access', '1'); } catch (e) {}
      </script>
      <div class="container">
        <div class="wholesale-form-wrapper">
          <div class="wholesale-success active">
            <div class="success-icon">
              {% render 'icon' with 'success' %}
            </div>
            <h2>{{ section.settings.success_heading }}</h2>
            <p>{{ section.settings.success_message }}</p>
            <div class="success-buttons">
              <a href="{{ section.settings.success_button_1_link }}" class="btn-shop">{{ section.settings.success_button_1_text }}</a>
              <a href="{{ section.settings.success_button_2_link }}" class="btn-apply">{{ section.settings.success_button_2_text }}</a>
            </div>
          </div>
        </div>
      </div>

    {%- elsif form.errors -%}
      <section class="error-ms">
        <div class="container">
          <div class="d-flex justify-content-center">
            <span class="d-flex align-item-center me-2">
              {% render 'icon' with 'error' %}
              <span class="error-text">{{ 'contact.form.error_message' | t }}</span>
            </span>
            <span>
              <a class="link" href="#WholesaleApplicationForm-email">
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email -}}
              </a>
            </span>
          </div>
        </div>
      </section>

      <div class="container">
        <div class="wholesale-form-wrapper">
          {% render 'wholesale-application-fields', form: form, section: section %}
        </div>
      </div>

    {%- else -%}
      <div class="container">
        <div class="wholesale-form-wrapper">
          {% render 'wholesale-application-fields', form: form, section: section %}
        </div>
      </div>
    {%- endif -%}
  {%- endform -%}
</section>

<script src="{{ 'wholesale-application.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Wholesale Application",
  "settings": [
    {
      "type": "header",
      "content": "Hero Section"
    },
    {
      "type": "color",
      "id": "hero_background",
      "label": "Hero Background Color",
      "default": "#026eb4"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Qualified Businesses Only"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Apply for a Wholesale Account"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Unlock exclusive business pricing, priority shipping, and flexible payment terms."
    },
    {
      "type": "header",
      "content": "Form Settings"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form Title",
      "default": "Business Application"
    },
    {
      "type": "text",
      "id": "form_subtitle",
      "label": "Form Subtitle",
      "default": "Fill out the form below and our team will review your application within one business day."
    },
    {
      "type": "header",
      "content": "Success Message"
    },
    {
      "type": "text",
      "id": "success_heading",
      "label": "Success Heading",
      "default": "Thank You for Applying!"
    },
    {
      "type": "textarea",
      "id": "success_message",
      "label": "Success Message",
      "default": "Our team will review your application and follow up shortly. Most business accounts are approved within one business day."
    },
    {
      "type": "text",
      "id": "success_button_1_text",
      "label": "Success Button 1 Text",
      "default": "Shop Gloves"
    },
    {
      "type": "url",
      "id": "success_button_1_link",
      "label": "Success Button 1 Link"
    },
    {
      "type": "text",
      "id": "success_button_2_text",
      "label": "Success Button 2 Text",
      "default": "Request Free Sample"
    },
    {
      "type": "url",
      "id": "success_button_2_link",
      "label": "Success Button 2 Link"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:settings_schema.global.section.padding.settings.padding_top.label",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:settings_schema.global.section.padding.settings.padding_bottom.label",
      "default": 20
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "Color scheme"
    }
  ],
  "presets": [
    {
      "name": "Wholesale Application Form"
    }
  ]
}
{% endschema %}
