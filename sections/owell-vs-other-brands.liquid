{% comment %}
  Owell vs. Other Brands Comparison Section
  Clean modern design with white background
{% endcomment %}

<style>
  .owell-comparison-wrapper {
    background: #ffffff;
    padding: 80px 20px;
    overflow: hidden;
    position: relative;
  }

  .owell-comparison-wrapper::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
      radial-gradient(circle at 10% 20%, rgba(86, 194, 179, 0.03) 0%, transparent 50%),
      radial-gradient(circle at 90% 80%, rgba(80, 82, 197, 0.03) 0%, transparent 50%);
    pointer-events: none;
  }

  .owell-comparison-container {
    max-width: 1300px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    padding: 0 20px;
  }

  .owell-comparison-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .owell-comparison-badge {
    display: inline-block;
    background: rgba(86, 194, 179, 0.1);
    border: 1px solid rgba(86, 194, 179, 0.2);
    color: #1a7f74;
    padding: 8px 20px;
    border-radius: 30px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .owell-comparison-title {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800;
    color: #1a1a1a;
    margin: 0 0 16px 0;
    letter-spacing: -0.5px;
  }

  .owell-comparison-subtitle {
    font-size: clamp(16px, 2vw, 20px);
    color: #666666;
    margin: 0;
    font-weight: 400;
  }

  .owell-comparison-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px;
    margin-bottom: 50px;
  }

  .owell-comparison-card {
    background: #ffffff;
    border: 2px solid #e5e7eb;
    border-radius: 24px;
    padding: 40px 32px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .owell-comparison-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #56c2b3, #5052c5);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .owell-comparison-card:hover::before {
    transform: scaleX(1);
  }

  .owell-comparison-card:hover {
    border-color: #56c2b3;
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
  }

  .owell-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 2px solid #f3f4f6;
  }

  .owell-card-title {
    font-size: 24px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
  }

  .owell-card-icon {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, #56c2b3, #5052c5);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: #ffffff;
    flex-shrink: 0;
  }

  .owell-card-content {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .owell-feature-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    animation: fadeInUp 0.6s ease-out backwards;
  }

  .owell-feature-item:nth-child(1) { animation-delay: 0.1s; }
  .owell-feature-item:nth-child(2) { animation-delay: 0.2s; }
  .owell-feature-item:nth-child(3) { animation-delay: 0.3s; }
  .owell-feature-item:nth-child(4) { animation-delay: 0.4s; }
  .owell-feature-item:nth-child(5) { animation-delay: 0.5s; }

  .owell-check-icon {
    width: 28px;
    height: 28px;
    background: linear-gradient(135deg, #56c2b3, #5052c5);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .owell-check-icon svg {
    width: 16px;
    height: 16px;
    stroke: white;
    stroke-width: 3;
    fill: none;
  }

  .owell-cross-icon {
    width: 28px;
    height: 28px;
    background: #fee2e2;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .owell-cross-icon svg {
    width: 16px;
    height: 16px;
    stroke: #ef4444;
    stroke-width: 3;
  }

  .owell-feature-text {
    flex: 1;
  }

  .owell-feature-title {
    font-size: 16px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 4px 0;
  }

  .owell-feature-description {
    font-size: 14px;
    color: #666666;
    margin: 0;
    line-height: 1.6;
  }

  .owell-cta-section {
    background: linear-gradient(135deg, #f0fdf4 0%, #eff6ff 100%);
    border: 2px solid #56c2b3;
    border-radius: 24px;
    padding: 48px 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .owell-cta-section::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(86, 194, 179, 0.05) 0%, transparent 70%);
    animation: pulse 4s ease-in-out infinite;
  }

  .owell-cta-content {
    position: relative;
    z-index: 1;
  }

  .owell-cta-title {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 800;
    color: #1a1a1a;
    margin: 0 0 12px 0;
  }

  .owell-cta-subtitle {
    font-size: 18px;
    color: #666666;
    margin: 0 0 32px 0;
  }

  .owell-cta-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: linear-gradient(135deg, #56c2b3, #5052c5);
    color: #ffffff;
    padding: 16px 40px;
    border-radius: 12px;
    font-size: 18px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    box-shadow: 0 10px 30px rgba(86, 194, 179, 0.25);
  }

  .owell-cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 40px rgba(86, 194, 179, 0.35);
    background: linear-gradient(135deg, #5052c5, #56c2b3);
  }

  .owell-guarantee {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 24px;
    color: #1a7f74;
    font-size: 14px;
    font-weight: 600;
  }

  .owell-guarantee svg {
    width: 20px;
    height: 20px;
    stroke: #56c2b3;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1) rotate(0deg);
    }
    50% {
      transform: scale(1.1) rotate(180deg);
    }
  }

  @media (max-width: 768px) {
    .owell-comparison-wrapper {
      padding: 60px 20px;
    }
    .owell-comparison-container {
      padding: 0;
    }
    .owell-comparison-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .owell-comparison-card {
      padding: 32px 24px;
    }

    .owell-cta-section {
      padding: 36px 24px;
    }
  }
</style>

