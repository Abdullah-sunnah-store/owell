{{ 'section-sample-request-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 | append: 'px' }};
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 | append: 'px' }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | append: 'px' }};
      padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
    }
  }
{%- endstyle -%}

<section
  class="sample-request section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}"
  aria-label="{{ section.settings.heading }}"
>
  <!-- Hero Banner -->
  <div class="sample-request__hero" style="background: {{ section.settings.hero_background }}; padding: 48px 40px 44px; text-align: center; margin-bottom: 40px;">
    <div class="sample-request__badge">{{ section.settings.badge_text }}</div>
    <h1 class="sample-request__title">{{ section.settings.heading }}</h1>
    <p class="sample-request__subtitle">{{ section.settings.subheading }}</p>
  </div>

  {%- form 'contact', id: 'SampleRequestForm', class: 'sample-request__form' -%}
    <!-- Hidden field to identify this as a sample request -->
    <input type="hidden" name="contact[Form Type]" value="Sample Request">

    {%- if form.posted_successfully? -%}
      <!-- Success Message -->
      <div class="container">
        <div class="sample-form-wrapper">
          <div class="sample-success active">
            <div class="success-icon">
              {% render 'icon' with 'success' %}
            </div>
            <h2>{{ section.settings.success_heading }}</h2>
            <p>{{ section.settings.success_message }}</p>
            <div class="success-buttons">
              <a href="{{ section.settings.success_button_1_link }}" class="btn-shop">{{ section.settings.success_button_1_text }}</a>
              <a href="{{ section.settings.success_button_2_link }}" class="btn-apply">{{ section.settings.success_button_2_text }}</a>
            </div>
          </div>
        </div>
      </div>

    {%- elsif form.errors -%}
      <!-- Error Message -->
      <section class="error-ms">
        <div class="container">
          <div class="d-flex justify-content-center">
            <span class="d-flex align-item-center me-2">
              {% render 'icon' with 'error' %}
              <span class="error-text">{{ 'contact.form.error_message' | t }}</span>
            </span>
            <span>
              <a class="link" href="#SampleRequestForm-email">
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email -}}
              </a>
            </span>
          </div>
        </div>
      </section>

      <div class="container">
        <div class="sample-form-wrapper">
          {% render 'sample-request-form-fields', form: form, section: section %}
        </div>
      </div>

    {%- else -%}
      <div class="container">
        <div class="sample-form-wrapper">
          {% render 'sample-request-form-fields', form: form, section: section %}
        </div>
      </div>
    {%- endif -%}
  {%- endform -%}
</section>

<script src="{{ 'sample-request-form.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Sample Request Form",
  "settings": [
    {
      "type": "header",
      "content": "Hero Section"
    },
    {
      "type": "color",
      "id": "hero_background",
      "label": "Hero Background Color",
      "default": "#026eb4"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Qualified Businesses Only"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Request a Complimentary Sample Box"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Designed for qualified businesses evaluating OWELL for professional use."
    },
    {
      "type": "header",
      "content": "Form Settings"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form Title",
      "default": "Sample Request"
    },
    {
      "type": "text",
      "id": "form_subtitle",
      "label": "Form Subtitle",
      "default": "Fill out the form below and our team will ship your samples within 2-3 business days."
    },
    {
      "type": "header",
      "content": "Success Message"
    },
    {
      "type": "text",
      "id": "success_heading",
      "label": "Success Heading",
      "default": "Sample Request Received!"
    },
    {
      "type": "textarea",
      "id": "success_message",
      "label": "Success Message",
      "default": "Our team will review your request and ship your samples within 2-3 business days. We'll follow up by email with your tracking details."
    },
    {
      "type": "text",
      "id": "success_button_1_text",
      "label": "Success Button 1 Text",
      "default": "Shop Gloves"
    },
    {
      "type": "url",
      "id": "success_button_1_link",
      "label": "Success Button 1 Link"
    },
    {
      "type": "text",
      "id": "success_button_2_text",
      "label": "Success Button 2 Text",
      "default": "Apply for Business Account"
    },
    {
      "type": "url",
      "id": "success_button_2_link",
      "label": "Success Button 2 Link"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:settings_schema.global.section.padding.settings.padding_top.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:settings_schema.global.section.padding.settings.padding_bottom.label",
      "default": 60
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "Color scheme"
    }
  ],
  "presets": [
    {
      "name": "Sample Request Form"
    }
  ]
}
{% endschema %}
