{% comment %}
  Features Banner Section
  
  Usage: Add this file to sections/ folder in your Shopify theme
  Displays trust badges/features in a horizontal layout
{% endcomment %}

<style>
  .features-banner-{{ section.id }} {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_vertical }}px {{ section.settings.padding_horizontal }}px;
  }

  .features-banner-container-{{ section.id }} {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
  }

  .features-banner-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
    gap: {{ section.settings.gap }}px;
    align-items: center;
  }

  .features-banner-item-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.item_alignment }};
    gap: {{ section.settings.icon_text_gap }}px;
  }

  .features-banner-icon-{{ section.id }} {
    flex-shrink: 0;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    color: {{ section.settings.icon_color }};
  }

  .features-banner-icon-{{ section.id }} svg {
    width: 100%;
    height: 100%;
  }

  .features-banner-text-{{ section.id }} {
    font-size: {{ section.settings.text_size }}px;
    font-weight: {{ section.settings.text_weight }};
    color: {{ section.settings.text_color }};
    text-transform: {{ section.settings.text_transform }};
    line-height: 1.2;
    letter-spacing: {{ section.settings.letter_spacing }}px;
  }

  @media (max-width: 1024px) {
    .features-banner-grid-{{ section.id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ section.settings.gap_mobile }}px;
    }
  }

  @media (max-width: 640px) {
    .features-banner-{{ section.id }} {
      padding: {{ section.settings.padding_vertical_mobile }}px {{ section.settings.padding_horizontal_mobile }}px;
    }

    .features-banner-grid-{{ section.id }} {
      grid-template-columns: 1fr 1fr;
      gap: {{ section.settings.gap_mobile }}px 0;
      justify-items: start;
    }

    .features-banner-text-{{ section.id }} {
      font-size: {{ section.settings.text_size_mobile }}px;
    }

    .features-banner-icon-{{ section.id }} {
      width: {{ section.settings.icon_size_mobile }}px;
      height: {{ section.settings.icon_size_mobile }}px;
    }
  }
</style>

<section class="features-banner-{{ section.id }}">
  <div class="features-banner-container-{{ section.id }}">
    <div class="features-banner-grid-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="features-banner-item-{{ section.id }}" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="features-banner-icon-{{ section.id }}">
              {{ block.settings.icon }}
            </div>
          {% endif %}
          {% if block.settings.text != blank %}
            <span class="features-banner-text-{{ section.id }}">
              {{ block.settings.text }}
            </span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

