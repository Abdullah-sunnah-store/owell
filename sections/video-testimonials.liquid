<style>
 #shopify-section-{{ section.id }} {
   --testimonial-background: {{ section.settings.background_gradient | default: section.settings.background }};
 }


 .video-testimonials {
   position: relative;
   overflow: hidden;
   padding: 60px 0;
 }


 .video-testimonials__carousel {
   overflow: hidden;
   padding: 0 5%;
 }


 .video-testimonials__container {
   display: flex;
   gap: 20px;
   align-items: center;
   justify-content: center;
   position: relative;
   flex-wrap: nowrap;
   overflow: visible;
   cursor: grab;
   user-select: none;
 }




 .video-testimonial {
   position: relative;
   border-radius: 20px;
   overflow: hidden;
   cursor: pointer;
   box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
   transform: scale(1) translateY(0);
   flex-shrink: 0;
 }


 .video-testimonials__container:not(.dragging) .video-testimonial {
   transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1),
               height 0.5s cubic-bezier(0.4, 0, 0.2, 1),
               box-shadow 0.5s cubic-bezier(0.4, 0, 0.2, 1),
               border-width 0.5s cubic-bezier(0.4, 0, 0.2, 1),
               transform 0.5s cubic-bezier(0.4, 0, 0.2, 1),
               order 0s;
 }


 .video-testimonial.hidden {
   opacity: 0;
   pointer-events: none;
 }


 /* 3D Carousel Positions */
 .video-testimonial.center {
   opacity: 1;
   box-shadow: 0 25px 50px rgba(0, 0, 0, 0.25);
   width: 270px;
   height: 480px;
   border: 4px solid #63b1a6;
 }


 .video-testimonial.left-3 {
   z-index: 0;
   box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
   width: 175px;
   height: 311px;
   border: 2.8px solid #39180F;
 }


 .video-testimonial.left-2 {
   z-index: 1;
   box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
   width: 218px;
   height: 388px;
   border: 3.2px solid #39180F;
 }


 .video-testimonial.left-1 {
   z-index: 5;
   width: 243px;
   height: 432px;
   box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
   border: 3.6px solid #39180F;
 }


 .video-testimonial.right-1 {
   z-index: 5;
   width: 243px;
   height: 432px;
   box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
   border: 3.6px solid #39180F;
 }


 .video-testimonial.right-2 {
   z-index: 1;
   width: 218px;
   height: 388px;
   box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
   border: 3.2px solid #39180F;
 }


 .video-testimonial.right-3 {
   z-index: 0;
   box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
   width: 175px;
   height: 311px;
   border: 2.8px solid #39180F;
 }


 .video-testimonial video {
   width: 100%;
   height: 100%;
   object-fit: cover;
 }


 .video-testimonial__poster {
   position: absolute;
   top: 0;
   left: 0;
   width: 100%;
   height: 100%;
   object-fit: cover;
   z-index: 2;
   cursor: pointer;
 }


 .video-testimonial__overlay {
   position: absolute;
   bottom: 0;
   left: 0;
   right: 0;
   background: linear-gradient(transparent, rgba(0,0,0,0.8));
   padding: 20px;
   z-index: 3;
   opacity: 0;
   transition: opacity 0.3s ease;
 }


 .video-testimonial.center .video-testimonial__overlay {
   opacity: 1;
 }


 .video-testimonial__product {
   display: flex;
   align-items: center;
   gap: 10px;
   background: #ECE5D4;
   padding: 8px 20px 8px 8px;
   border-radius: 8px;
 }


 .video-testimonial__product-image {
   width: 64px;
   height: 64px;
   border-radius: 4px;
   object-fit: cover;
 }


 .video-testimonial__product-name {
   color: #39180FB2;
   font-size: 14px;
   display: flex;
   font-weight: 700;
   flex-direction: column;
   align-items: flex-start;
 }


 .video-testimonial__shop-button {
     color: #333;
   border: none;
   border-radius: 20px;
   font-size: 13px;
   font-weight: 500;
   cursor: pointer;
   text-decoration: underline;
   transition: all 0.3s ease;
 }


 .video-testimonial__controls {
   position: absolute;
   top: 15px;
   right: 15px;
   z-index: 4;
   opacity: 0;
   transition: opacity 0.3s ease;
 }


 .video-testimonial.center .video-testimonial__controls {
   opacity: 1;
 }


 .video-testimonial__mute-button {
   background: transparent;
   border: 1px solid #FFFFFF1A !important;
   border-radius: 6px;
   width: 40px;
   height: 40px;
   color: white;
   cursor: pointer;
   display: flex;
   align-items: center;
   justify-content: center;
   transition: all 0.3s ease;
 }


 .video-testimonial__mute-button:hover {
   border-color: #fff !important;
 }
 .left-3 .video-testimonial__play-button{
   display: none !important;
 }
 .left-2 .video-testimonial__play-button{
   display: none !important;
 }
 .left-1 .video-testimonial__play-button{
   display: none !important;
 }
 .right-1 .video-testimonial__play-button{
   display: none !important;
 }
 .right-2 .video-testimonial__play-button{
   display: none !important;
 }
 .right-3 .video-testimonial__play-button{
   display: none !important;
 }


 .video-testimonial__play-button {
   position: absolute;
   top: 50%;
   left: 50%;
   transform: translate(-50%, -50%);
   background: rgba(255, 255, 255, 0.9);
   border: none;
   border-radius: 50%;
   width: 60px;
   height: 60px;
   cursor: pointer;
   z-index: 4;
   display: flex;
   align-items: center;
   justify-content: center;
   transition: all 0.3s ease;
 }


 .video-testimonial__play-button:hover {
   background: white;
   transform: translate(-50%, -50%) scale(1.1);
 }


 .video-testimonial__play-button.playing {
   display: none;
 }


 /* Navigation */
 .video-testimonials__navigation {
   display: flex;
   justify-content: center;
   align-items: center;
   gap: 40px;
   margin-top: 40px;
 }


 .video-testimonials__arrow {
   background:#daf5f2;
   border-radius: 40px;
   width: 88px;
   height: 56px;
   cursor: pointer;
   display: flex;
   align-items: center;
   justify-content: center;
   transition: all 0.3s ease;
   border: 1px solid #39180F1A;
 }


 .video-testimonials__arrow:hover {
   border-color: #000 !important;
 }


 .video-testimonials__dots {
   display: flex;
   gap: 8px;
 }


 .video-testimonials__dot {
   width: 12px;
   height: 12px;
   border-radius: 50%;
   background: #39180F3D;
   border: none;
   cursor: pointer;
   transition: all 0.3s ease;
 }


 .video-testimonials__dot.active {
   background: #5052c5;
   width: 32px;
   border-radius: 40px !important;
 }


 /* Section header */
 .video-testimonials__header {
   text-align: center;
   margin-bottom: 50px;
 }


 .video-testimonials__title {
   font-size: clamp(24px, 4vw, 48px);
   margin-bottom: 10px;
   color: {{ section.settings.text_color }};
 }


 .video-testimonials__subtitle {
   font-size: clamp(14px, 2vw, 18px);
   color: {{ section.settings.text_color }};
   opacity: 0.8;
 }


 /* Responsive breakpoints */


 /* Tablets and small desktops - 5 slides */
 @media (max-width: 1440px) {
   .video-testimonial.left-3,
   .video-testimonial.right-3 {
     display: none;
   }
 }


 /* Mobile landscape and small tablets - 3 slides */
 @media (max-width: 768px) {
   .video-testimonial.left-2,
   .video-testimonial.right-2,
   .video-testimonial.left-3,
   .video-testimonial.right-3 {
     display: none;
   }


   .video-testimonials__navigation {
     gap: 20px;
     margin-top: 30px;
   }


   .video-testimonials__arrow {
     width: 40px;
     height: 40px;
   }


   .video-testimonial__play-button {
     width: 50px;
     height: 50px;
   }
 }


 /* Mobile portrait - button sizing */
 @media (max-width: 480px) {
   .video-testimonials__arrow {
     width: 36px;
     height: 36px;
   }
 }
</style>


