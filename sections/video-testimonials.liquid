<script>
 let currentIndex = 0;
 const totalSlides = {{ section.blocks.size }};
 let testimonials = [];
 let isAnimating = false;


 function updateCarousel(newIndex) {
   if (isAnimating) return;
   isAnimating = true;


   // Handle infinite loop in both directions
   currentIndex = ((newIndex % totalSlides) + totalSlides) % totalSlides;


   // Update position classes for all testimonials without removing from DOM
   testimonials.forEach((item, index) => {
     // Remove all position classes
     item.classList.remove(
       "center",
       "left-1",
       "left-2",
       "left-3",
       "right-1",
       "right-2",
       "right-3",
       "hidden"
     );


     // Calculate relative position from current index
     let relativePosition = index - currentIndex;


     // Handle circular wrapping
     if (relativePosition > Math.floor(totalSlides / 2)) {
       relativePosition -= totalSlides;
     } else if (relativePosition < -Math.floor(totalSlides / 2)) {
       relativePosition += totalSlides;
     }


     // Apply position class based on relative position
     switch (relativePosition) {
       case -3:
         item.classList.add("left-3");
         item.style.order = 0;
         break;
       case -2:
         item.classList.add("left-2");
         item.style.order = 1;
         break;
       case -1:
         item.classList.add("left-1");
         item.style.order = 2;
         break;
       case 0:
         item.classList.add("center");
         item.style.order = 3;
         break;
       case 1:
         item.classList.add("right-1");
         item.style.order = 4;
         break;
       case 2:
         item.classList.add("right-2");
         item.style.order = 5;
         break;
       case 3:
         item.classList.add("right-3");
         item.style.order = 6;
         break;
       default:
         item.classList.add("hidden");
         item.style.order = 7;
         break;
     }
   });


   updateDots();
   updateVideoStates();


   setTimeout(() => {
     isAnimating = false;
   }, 500);
 }


 function slideTestimonials(direction) {
   const newIndex = currentIndex + direction;
   updateCarousel(newIndex);
 }


 function goToSlide(slideIndex) {
   updateCarousel(slideIndex);
 }


 function updateVideoStates() {
   const allVideos = document.querySelectorAll('.video-testimonial video');
   const allPlayButtons = document.querySelectorAll('.video-testimonial__play-button');


   // Pause all videos first
   allVideos.forEach(video => {
     video.pause();
     video.currentTime = 0;
   });


   allPlayButtons.forEach(button => {
     button.style.display = 'flex';
   });


   // Only play the center video
   const centerVideo = document.querySelector('.video-testimonial.center video');
   const centerPlayButton = document.querySelector('.video-testimonial.center .video-testimonial__play-button');


   if (centerVideo) {
     centerVideo.play();
     if (centerPlayButton) {
       centerPlayButton.style.display = 'none';
     }
   }
 }


 function updateDots() {
   document.querySelectorAll('.video-testimonials__dot').forEach((dot, index) => {
     dot.classList.toggle('active', index === currentIndex);
   });
 }


 function toggleVideo(button) {
   const video = button.parentElement.querySelector('video');
   if (video && video.paused) {
     video.play();
     button.style.display = 'none';
   }
 }


 function toggleMute(button) {
   const allVideos = document.querySelectorAll('.video-testimonial video');
   const allMuteButtons = document.querySelectorAll('.video-testimonial__mute-button');
   const video = button.closest('.video-testimonial').querySelector('video');


   if (video) {
     const newMutedState = !video.muted;


     // Apply mute state to all videos
     allVideos.forEach(v => {
       v.muted = newMutedState;
     });


     // Update all mute button icons
     allMuteButtons.forEach(btn => {
       const muteIcon = btn.querySelector('.mute-icon');
       const unmuteIcon = btn.querySelector('.unmute-icon');


       if (newMutedState) {
         muteIcon.style.display = 'block';
         unmuteIcon.style.display = 'none';
       } else {
         muteIcon.style.display = 'none';
         unmuteIcon.style.display = 'block';
       }
     });
   }
 }


 // Initialize on load
 document.addEventListener('DOMContentLoaded', function() {
   testimonials = Array.from(document.querySelectorAll('.video-testimonial'));


   // Set initial state
   updateCarousel(0);


   // Add click handlers to testimonials to center them
   testimonials.forEach((testimonial, index) => {
     testimonial.addEventListener('click', (e) => {
       // Don't trigger if clicking on mute button or other controls, or if user was dragging
       if (!hasDragged &&
           !e.target.closest('.video-testimonial__mute-button') &&
           !e.target.closest('.video-testimonial__play-button') &&
           !e.target.closest('.video-testimonial__shop-button')) {
         updateCarousel(index);
       }
     });
   });


   // Drag/Swipe functionality
   const container = document.getElementById('testimonials-container');
   let isDragging = false;
   let startPos = 0;
   let currentTranslate = 0;
   let prevTranslate = 0;
   let animationID = 0;
   let hasDragged = false;


   // Mouse events
   container.addEventListener('mousedown', dragStart);
   container.addEventListener('mouseup', dragEnd);
   container.addEventListener('mouseleave', dragEnd);
   container.addEventListener('mousemove', drag);


   // Touch events
   container.addEventListener('touchstart', dragStart);
   container.addEventListener('touchend', dragEnd);
   container.addEventListener('touchmove', drag);


   function dragStart(event) {
     isDragging = true;
     hasDragged = false;
     startPos = getPositionX(event);
     animationID = requestAnimationFrame(animation);
     container.style.cursor = 'grabbing';
     container.classList.add('dragging');
   }


   function drag(event) {
     if (!isDragging) return;
     event.preventDefault();
     const currentPosition = getPositionX(event);
     currentTranslate = currentPosition - startPos;


     // Mark as dragged if moved more than 5px
     if (Math.abs(currentTranslate) > 5) {
       hasDragged = true;
     }
   }


   function dragEnd() {
     if (!isDragging) return;
     isDragging = false;
     cancelAnimationFrame(animationID);
     container.style.cursor = 'grab';
     container.classList.remove('dragging');


     const movedBy = currentTranslate;


     // If moved more than 50px, change slide (infinite loop)
     if (movedBy < -50) {
       slideTestimonials(1);
     } else if (movedBy > 50) {
       slideTestimonials(-1);
     }


     // Reset container transform
     container.style.transform = '';
     currentTranslate = 0;


     // Reset hasDragged after a short delay to allow click event to check it
     setTimeout(() => {
       hasDragged = false;
     }, 10);
   }


   function getPositionX(event) {
     return event.type.includes('mouse') ? event.pageX : event.touches[0].clientX;
   }


   function animation() {
     if (isDragging) {
       setContainerPosition();
       requestAnimationFrame(animation);
     }
   }


   function setContainerPosition() {
     container.style.transform = `translateX(${currentTranslate}px)`;
   }


   // Auto-play functionality
   {% if section.settings.autoplay %}
     setInterval(() => {
       if (!isAnimating && !isDragging) {
         slideTestimonials(1);
       }
     }, {{ section.settings.duration | times: 1000 }});
   {% endif %}
 });
</script>


