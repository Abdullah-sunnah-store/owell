<style>
    .trust-badges-section {
        background-color: #fff;
        padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px 20px;
    }
    .trust-badges-container {
        display: flex;
        flex-direction: column;
        max-width: 120rem;
        margin: 0 auto;
    }
    .trust-badges-grid {
        display: flex;
        flex-direction: row;
        gap: 20px;
        color: #000;
        text-align: center;
        justify-content: center;
        align-items: flex-start;
    }
    .trust-badge-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
        min-width: 0;
    }
    .trust-badge-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        color: inherit;
        width: 100%;
        transition: transform 0.2s ease, opacity 0.2s ease;
        gap: 10px;
    }
    .trust-badge-link:hover {
        transform: translateY(-5px);
        opacity: 0.85;
    }
    .trust-badge-item img {
        height: 75px;
        width: 75px;
        object-fit: contain;
        flex-shrink: 0;
    }
    /* Always single line — no wrapping ever */
    .trust-badge-label {
        display: block;
        font-weight: 600;
        font-size: 18px;
        color: #000;
        line-height: 1.3;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        width: 100%;
        text-align: center;
    }
    .trust-badge-item p {
        font-size: 14px;
        line-height: 1.4;
        margin: 0;
        color: #444;
    }

    /* Tablet */
    @media screen and (max-width: 992px) {
        .trust-badges-section {
            padding: {{ section.settings.padding_top_tablet }}px 15px {{ section.settings.padding_bottom_tablet }}px 15px;
        }
        .trust-badges-grid {
            gap: 16px;
        }
        .trust-badge-item img {
            height: 65px;
            width: 65px;
        }
        .trust-badge-label {
            font-size: 16px;
        }
        .trust-badge-item p {
            font-size: 13px;
        }
    }

    /* Mobile */
    @media screen and (max-width: 768px) {
        .trust-badges-section {
            padding: {{ section.settings.padding_top_mobile }}px 10px {{ section.settings.padding_bottom_mobile }}px 10px;
        }
        .trust-badges-grid {
            gap: 8px;
        }
        .trust-badge-link {
            gap: 8px;
        }
        .trust-badge-item img {
            height: 52px;
            width: 52px;
        }
        .trust-badge-label {
            font-size: 14px;
        }
        .trust-badge-item p {
            display: none;
        }
    }

    /* Small mobile */
    @media screen and (max-width: 480px) {
        .trust-badges-grid {
            gap: 4px;
        }
        .trust-badge-item img {
            height: 46px;
            width: 46px;
        }
        .trust-badge-label {
            font-size: 12px;
        }
    }

    /* Very small */
    @media screen and (max-width: 360px) {
        .trust-badge-item img {
            height: 40px;
            width: 40px;
        }
        .trust-badge-label {
            font-size: 10px;
        }
    }
</style>

<div class="container trust-badges-section">
    <div class="trust-badges-container">
        <div class="trust-badges-grid">

            {% if section.settings.badge_1_image != blank %}
            <div class="trust-badge-item">
                {% if section.settings.badge_1_link != blank %}
                <a href="{{ section.settings.badge_1_link }}" class="trust-badge-link">
                {% else %}
                <div class="trust-badge-link">
                {% endif %}
                    <img src="{{ section.settings.badge_1_image | img_url: 'master' }}" alt="{{ section.settings.badge_1_title }}">
                    <span class="trust-badge-label">{{ section.settings.badge_1_title }}</span>
                    {% if section.settings.badge_1_text != blank %}<p>{{ section.settings.badge_1_text }}</p>{% endif %}
                {% if section.settings.badge_1_link != blank %}
                </a>
                {% else %}
                </div>
                {% endif %}
            </div>
            {% endif %}

            {% if section.settings.badge_2_image != blank %}
            <div class="trust-badge-item">
                {% if section.settings.badge_2_link != blank %}
                <a href="{{ section.settings.badge_2_link }}" class="trust-badge-link">
                {% else %}
                <div class="trust-badge-link">
                {% endif %}
                    <img src="{{ section.settings.badge_2_image | img_url: 'master' }}" alt="{{ section.settings.badge_2_title }}">
                    <span class="trust-badge-label">{{ section.settings.badge_2_title }}</span>
                    {% if section.settings.badge_2_text != blank %}<p>{{ section.settings.badge_2_text }}</p>{% endif %}
                {% if section.settings.badge_2_link != blank %}
                </a>
                {% else %}
                </div>
                {% endif %}
            </div>
            {% endif %}

            {% if section.settings.badge_3_image != blank %}
            <div class="trust-badge-item">
                {% if section.settings.badge_3_link != blank %}
                <a href="{{ section.settings.badge_3_link }}" class="trust-badge-link">
                {% else %}
                <div class="trust-badge-link">
                {% endif %}
                    <img src="{{ section.settings.badge_3_image | img_url: 'master' }}" alt="{{ section.settings.badge_3_title }}">
                    <span class="trust-badge-label">{{ section.settings.badge_3_title }}</span>
                    {% if section.settings.badge_3_text != blank %}<p>{{ section.settings.badge_3_text }}</p>{% endif %}
                {% if section.settings.badge_3_link != blank %}
                </a>
                {% else %}
                </div>
                {% endif %}
            </div>
            {% endif %}

        </div>
    </div>
</div>

{% schema %}
{
  "name": "Trust Badges Section",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Tablet)",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Tablet)",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 24
    },
    {
      "type": "header",
      "content": "Badge 1"
    },
    {
      "type": "image_picker",
      "id": "badge_1_image",
      "label": "Badge 1 Image"
    },
    {
      "type": "text",
      "id": "badge_1_title",
      "label": "Badge 1 Title",
      "default": "FDA-Registered"
    },
    {
      "type": "textarea",
      "id": "badge_1_text",
      "label": "Badge 1 Text (Desktop only)"
    },
    {
      "type": "url",
      "id": "badge_1_link",
      "label": "Badge 1 Link (Optional)"
    },
    {
      "type": "header",
      "content": "Badge 2"
    },
    {
      "type": "image_picker",
      "id": "badge_2_image",
      "label": "Badge 2 Image"
    },
    {
      "type": "text",
      "id": "badge_2_title",
      "label": "Badge 2 Title",
      "default": "ISO Certified"
    },
    {
      "type": "textarea",
      "id": "badge_2_text",
      "label": "Badge 2 Text (Desktop only)"
    },
    {
      "type": "url",
      "id": "badge_2_link",
      "label": "Badge 2 Link (Optional)"
    },
    {
      "type": "header",
      "content": "Badge 3"
    },
    {
      "type": "image_picker",
      "id": "badge_3_image",
      "label": "Badge 3 Image"
    },
    {
      "type": "text",
      "id": "badge_3_title",
      "label": "Badge 3 Title",
      "default": "Food Safe Certified"
    },
    {
      "type": "textarea",
      "id": "badge_3_text",
      "label": "Badge 3 Text (Desktop only)"
    },
    {
      "type": "url",
      "id": "badge_3_link",
      "label": "Badge 3 Link (Optional)"
    }
  ],
  "presets": [
    {
      "name": "Trust Badges Section"
    }
  ]
}
{% endschema %}
