{% comment %}
  Customer Reviews Section with Trustpilot Integration
  Fully dynamic and customizable through Shopify theme editor
{% endcomment %}

<style>
  .reviews-section-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }

  .reviews-container-{{ section.id }} {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .reviews-header-{{ section.id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .reviews-header-{{ section.id }} h2 {
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.heading_color }};
    margin-bottom: 8px;
    font-weight: {{ section.settings.heading_weight }};
    line-height: 1.2;
  }

  .reviews-header-{{ section.id }} h3 {
    font-size: {{ section.settings.subheading_size }}px;
    color: {{ section.settings.subheading_color }};
    font-weight: {{ section.settings.subheading_weight }};
    margin-bottom: 20px;
  }

  .trustpilot-badge-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 20px;
  }

  .trustpilot-rating-{{ section.id }} {
    font-size: {{ section.settings.rating_size }}px;
    font-weight: 600;
    color: {{ section.settings.rating_color }};
  }

  .trustpilot-stars-{{ section.id }} {
    display: flex;
    gap: 4px;
  }

  .trustpilot-stars-{{ section.id }} img {
    width: {{ section.settings.star_size }}px;
    height: {{ section.settings.star_size }}px;
    object-fit: contain;
  }

  .trustpilot-logo-{{ section.id }} img {
    height: {{ section.settings.logo_height }}px;
    width: auto;
  }

  .review-count-{{ section.id }} {
    font-size: {{ section.settings.review_count_size }}px;
    color: {{ section.settings.review_count_color }};
  }

  .reviews-carousel-wrapper-{{ section.id }} {
    position: relative;
    margin-top: 40px;
  }

  .carousel-header-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 30px;
  }

  .carousel-header-{{ section.id }} h3 {
    font-size: {{ section.settings.carousel_heading_size }}px;
    color: {{ section.settings.carousel_heading_color }};
    font-weight: 600;
    margin: 0;
  }

  .carousel-controls-{{ section.id }} {
    display: flex;
    gap: 12px;
  }

  .carousel-control-{{ section.id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: {{ section.settings.control_bg_color }};
    border: 1px solid {{ section.settings.control_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .carousel-control-{{ section.id }}:hover {
    background: {{ section.settings.control_hover_bg }};
    transform: scale(1.05);
  }

  .carousel-control-{{ section.id }} svg {
    width: 20px;
    height: 20px;
    fill: {{ section.settings.control_icon_color }};
  }

  .reviews-carousel-{{ section.id }} {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .reviews-carousel-{{ section.id }}::-webkit-scrollbar {
    display: none;
  }

  .review-card-{{ section.id }} {
    min-width: {{ section.settings.card_width }}px;
    background: {{ section.settings.card_bg_color }};
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    padding: {{ section.settings.card_padding }}px;
    box-shadow: {{ section.settings.card_shadow }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .review-card-header-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    margin-bottom: 16px;
  }

  .review-stars-{{ section.id }} {
    display: flex;
    gap: 4px;
  }

  .review-stars-{{ section.id }} img {
    width: {{ section.settings.review_star_size }}px;
    height: {{ section.settings.review_star_size }}px;
    object-fit: contain;
  }

  .review-trustpilot-logo-{{ section.id }} {
    flex-shrink: 0;
  }

  .review-trustpilot-logo-{{ section.id }} img {
    height: {{ section.settings.review_card_logo_height }}px;
    width: auto;
    object-fit: contain;
  }

  .review-text-{{ section.id }} {
    font-size: {{ section.settings.review_text_size }}px;
    line-height: 1.6;
    color: {{ section.settings.review_text_color }};
    margin-bottom: 20px;
  }

  .review-author-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .author-avatar-{{ section.id }} {
    width: {{ section.settings.avatar_size }}px;
    height: {{ section.settings.avatar_size }}px;
    border-radius: 50%;
    overflow: hidden;
  }

  .author-avatar-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .author-info-{{ section.id }} h4 {
    font-size: {{ section.settings.author_name_size }}px;
    font-weight: 600;
    color: {{ section.settings.author_name_color }};
    margin: 0 0 4px 0;
  }

  .author-info-{{ section.id }} p {
    font-size: {{ section.settings.author_date_size }}px;
    color: {{ section.settings.author_date_color }};
    margin: 0;
  }

  @media (max-width: 768px) {
    .review-card-{{ section.id }} {
      min-width: 280px;
    }
   .carousel-controls-{{ section.id }} {
    display: none;
  }
    .carousel-header-{{ section.id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .reviews-header-{{ section.id }} h2 {
      font-size: calc({{ section.settings.heading_size }}px * 0.8);
    }

    .reviews-header-{{ section.id }} h3 {
      font-size: calc({{ section.settings.subheading_size }}px * 0.8);
    }
  }
</style>

<section class="reviews-section-{{ section.id }}">
  <div class="reviews-container-{{ section.id }}">
    
    <!-- Header Section -->
    <div class="reviews-header-{{ section.id }}">
      {% if section.settings.show_heading %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      
      {% if section.settings.show_subheading %}
        <h3>{{ section.settings.subheading }}</h3>
      {% endif %}

      <!-- Trustpilot Badge -->
      {% if section.settings.show_trustpilot %}
        <div class="trustpilot-badge-{{ section.id }}">
          <span class="trustpilot-rating-{{ section.id }}">{{ section.settings.trustpilot_rating }}</span>
          
          <div class="trustpilot-stars-{{ section.id }}">
            {% if section.settings.star_full_image %}
              {% assign rating_decimal = section.settings.trustpilot_rating | times: 1.0 %}
              {% assign full_stars = rating_decimal | floor %}
              {% assign remaining = rating_decimal | minus: full_stars %}
              {% assign next_star = full_stars | plus: 1 %}
              
              {% for i in (1..5) %}
                {% if i <= full_stars %}
                  <img src="{{ section.settings.star_full_image | img_url: 'master' }}" alt="Full star">
                {% elsif i == next_star and remaining > 0 and section.settings.star_half_image %}
                  <img src="{{ section.settings.star_half_image | img_url: 'master' }}" alt="Half star">
                {% elsif section.settings.star_empty_image %}
                  <img src="{{ section.settings.star_empty_image | img_url: 'master' }}" alt="Empty star">
                {% endif %}
              {% endfor %}
            {% endif %}
          </div>

          {% if section.settings.show_trustpilot_logo and section.settings.trustpilot_logo %}
            <div class="trustpilot-logo-{{ section.id }}">
              <img src="{{ section.settings.trustpilot_logo | img_url: 'master' }}" alt="Trustpilot">
            </div>
          {% endif %}

          {% if section.settings.show_review_count %}
            <span class="review-count-{{ section.id }}">
              {{ section.settings.review_count_text }}
            </span>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <!-- Reviews Carousel -->
    <div class="reviews-carousel-wrapper-{{ section.id }}">
      <div class="carousel-header-{{ section.id }}">
        <h3>{{ section.settings.carousel_heading }}</h3>
        
        <div class="carousel-controls-{{ section.id }}">
          <button class="carousel-control-{{ section.id }} carousel-prev-{{ section.id }}" aria-label="Previous reviews">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
            </svg>
          </button>
          <button class="carousel-control-{{ section.id }} carousel-next-{{ section.id }}" aria-label="Next reviews">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="reviews-carousel-{{ section.id }}" id="reviewsCarousel{{ section.id }}">
        {% for block in section.blocks %}
          <div class="review-card-{{ section.id }}" {{ block.shopify_attributes }}>
            
            <!-- Card Header with Stars and Trustpilot Logo -->
            <div class="review-card-header-{{ section.id }}">
              <!-- Star Rating -->
              <div class="review-stars-{{ section.id }}">
                {% if section.settings.review_star_full_image %}
                  {% for i in (1..5) %}
                    {% if i <= block.settings.rating %}
                      <img src="{{ section.settings.review_star_full_image | img_url: 'master' }}" alt="Full star">
                    {% elsif section.settings.review_star_empty_image %}
                      <img src="{{ section.settings.review_star_empty_image | img_url: 'master' }}" alt="Empty star">
                    {% endif %}
                  {% endfor %}
                {% endif %}
              </div>

              <!-- Trustpilot Logo on Card -->
              {% if section.settings.show_review_card_logo and section.settings.review_card_trustpilot_logo %}
                <div class="review-trustpilot-logo-{{ section.id }}">
                  <img src="{{ section.settings.review_card_trustpilot_logo | img_url: 'master' }}" alt="Trustpilot">
                </div>
              {% endif %}
            </div>

            <!-- Review Text -->
            <div class="review-text-{{ section.id }}">
              {{ block.settings.review_text }}
            </div>

            <!-- Author Info -->
            <div class="review-author-{{ section.id }}">
              {% if block.settings.author_image %}
                <div class="author-avatar-{{ section.id }}">
                  <img src="{{ block.settings.author_image | img_url: 'master' }}" alt="{{ block.settings.author_name }}">
                </div>
              {% endif %}
              
              <div class="author-info-{{ section.id }}">
                <h4>{{ block.settings.author_name }}</h4>
                <p>{{ block.settings.review_date }}</p>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

  </div>
</section>

<script>
  (function() {
    const carousel = document.getElementById('reviewsCarousel{{ section.id }}');
    const prevBtn = document.querySelector('.carousel-prev-{{ section.id }}');
    const nextBtn = document.querySelector('.carousel-next-{{ section.id }}');
    
    if (carousel && prevBtn && nextBtn) {
      const scrollAmount = {{ section.settings.card_width }} + 24; // card width + gap
      
      prevBtn.addEventListener('click', () => {
        carousel.scrollBy({
          left: -scrollAmount,
          behavior: 'smooth'
        });
      });
      
      nextBtn.addEventListener('click', () => {
        carousel.scrollBy({
          left: scrollAmount,
          behavior: 'smooth'
        });
      });
    }
  })();
</script>

