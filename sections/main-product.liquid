{% endunless %}
  <form id="bulk-order-form">
    <table>
      <thead>
        <tr>
          <th>Variant</th>
          <th>Price</th>
          <th>Business Price</th>
          <th>SKU</th>
          <th>Quantity</th>
        </tr>
      </thead>
      <tbody>
        {% for variant in product.variants %}
          {% assign parts = variant.title | split: " / " %}
{% assign color = parts[0] | downcase %}
{% assign size = parts[1] %}
          <tr class="row-variant-id{{ variant.id }}">
            <td><div class="main--cominss"><div class="color--{{ color }}"></div> {{ size }}</div></td>
            <td>           
          {{ WCProduct_VariantPrice | money }}
          {% if WCProduct_VariantComparePrice %}
            <del>{{ WCProduct_VariantComparePrice | money }}</del>
          {% endif %}
          </td>
            <td style="background-color: #e0e0e0; padding: 0; margin: 0;"><div class="b2b-business-price" style=" text-align: center; color: #000000">$42.50</div></td>
            <td>{{ variant.sku }}</td>
