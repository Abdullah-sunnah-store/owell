  {% comment %} ============================================ {% endcomment %}
  {% comment %} PRODUCT FEATURE HIGHLIGHTS STYLES {% endcomment %}
  {% comment %} ============================================ {% endcomment %}
  .product-feature-highlights {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 16px;
    background: #026eb4;
    border: none;
    padding: 20px;
  }

  .product-feature-highlights__item {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #026EB4;
    border: 2px solid #ffffff;
    border-radius: 10px;
    padding: 12px 14px;
  }

  .product-feature-highlights__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #ffffff;
    width: 32px;
    height: 32px;
  }

  .product-feature-highlights__icon svg {
    width: 45px;
    height: 45px;
  }

  .product-feature-highlights__text {
    font-size: 12px;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.25;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  /* Desktop: hide the mobile-only copy */
  @media screen and (min-width: 750px) {
    .product-feature-highlights--mobile-only {
      display: none !important;
    }
  }
/* Remove the desktop highlights from inside the product info column */
