                    </div>
                    <div class="ss-check-{{ block.id }}">
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="2 6 5 9 10 3"></polyline>
                      </svg>
                    </div>
