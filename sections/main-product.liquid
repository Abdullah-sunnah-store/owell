                        </option>
                      {% endfor %}
                    </select>
                  </div>
                  {% endcomment %}

                  <!-- Bundle Options -->
                  <div class="bundle-options-{{ block.id }}" id="bundle-selector-{{ block.id }}">

                    <!-- Option 1: Buy 1 -->
                    <label class="bundle-option-{{ block.id }} selected" data-quantity="1" data-bundle-index="0">
                      <input type="radio" name="bundle-{{ block.id }}" value="1" checked>
                      <div class="bundle-content-{{ block.id }}">
                        <h4 class="bundle-title-{{ block.id }}">{{ block.settings.bundle_1_title }}</h4>
                        <p class="bundle-savings-{{ block.id }}">{{ block.settings.bundle_1_savings }}</p>
                      </div>
                      <div class="bundle-pricing-{{ block.id }}">
                        <p class="bundle-price-{{ block.id }}" data-bundle-price>Loading...</p>
                        <p class="bundle-compare-price-{{ block.id }}" data-bundle-compare style="display:none;">-</p>
                      </div>
                    </label>

                    <!-- Option 2: Buy 4+ (Save 5%) -->
                    <label class="bundle-option-{{ block.id }}" data-quantity="{{ block.settings.bundle_2_quantity }}" data-bundle-index="1">
                      <input type="radio" name="bundle-{{ block.id }}" value="2">
                      <div class="bundle-content-{{ block.id }}">
                        <h4 class="bundle-title-{{ block.id }}">{{ block.settings.bundle_2_title }}</h4>
                        <p class="bundle-savings-{{ block.id }}">{{ block.settings.bundle_2_savings }}</p>
                      </div>
                      <div class="bundle-pricing-{{ block.id }}">
                        <p class="bundle-price-{{ block.id }}" data-bundle-price>Loading...</p>
                        <p class="bundle-compare-price-{{ block.id }}" data-bundle-compare style="display:none;">-</p>
                      </div>
                      <span class="bundle-label-{{ block.id }}" style="background: {{ block.settings.bundle_2_label_bg }};">
                        {{ block.settings.bundle_2_label }}
                      </span>
                    </label>

                  </div>
                </div>

                <script>
                document.addEventListener('DOMContentLoaded', function() {
                  var bundleSelector = document.getElementById('bundle-selector-{{ block.id }}');
                  if (!bundleSelector) return;
                  var bundleOptions = Array.from(bundleSelector.querySelectorAll('.bundle-option-{{ block.id }}'));

                  var variantPrices = {
                    {% for variant in product.variants %}
                      {{ variant.id }}: {{ variant.price }}{% unless forloop.last %},{% endunless %}
                    {% endfor %}
                  };

                  var bundleConfig = [
                    { quantity: 1,                                      discount: 0 },
                    { quantity: {{ block.settings.bundle_2_quantity }}, discount: {{ block.settings.bundle_2_discount | default: 5 }} }
                  ];

                  var selectedVariantPrice = {{ product.selected_or_first_available_variant.price }};
                  var moneyFormat = {{ shop.money_format | json }};

                  function formatMoney(cents) {
                    if (window.Shopify && window.Shopify.formatMoney) {
                      return window.Shopify.formatMoney(cents, moneyFormat);
                    }
                    return '$' + (cents / 100).toFixed(2);
                  }

                  function updateBundlePrices() {
                    bundleOptions.forEach(function(option, index) {
                      var config = bundleConfig[index];
                      var priceEl   = option.querySelector('[data-bundle-price]');
                      var compareEl = option.querySelector('[data-bundle-compare]');
                      if (!priceEl) return;

                      var fullPrice      = selectedVariantPrice * config.quantity;
                      var discounted     = Math.round(fullPrice * (1 - config.discount / 100));

                      priceEl.textContent = formatMoney(discounted);

                      if (compareEl) {
                        if (config.discount > 0) {
                          compareEl.textContent    = formatMoney(fullPrice);
                          compareEl.style.display  = 'block';
                        } else {
                          compareEl.style.display  = 'none';
                        }
                      }
                    });
                  }

                  function setQuantity(qty) {
                    // Try all common quantity input selectors
                    var selectors = [
                      'input[name="quantity"]',
                      '.quantity__input',
                      '[data-quantity-input]',
                      'input[type="number"][min]'
                    ];
                    var input = null;
                    for (var i = 0; i < selectors.length; i++) {
                      input = document.querySelector(selectors[i]);
                      if (input) break;
                    }
                    if (!input) return;

                    // Use native setter so framework-controlled inputs detect the change
                    var nativeSetter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value').set;
                    nativeSetter.call(input, qty);
                    input.dispatchEvent(new Event('input',  { bubbles: true }));
                    input.dispatchEvent(new Event('change', { bubbles: true }));
                  }

                  function handleVariantChange(variantId) {
                    variantId = parseInt(variantId);
                    if (variantPrices[variantId] !== undefined) {
                      selectedVariantPrice = variantPrices[variantId];
                      updateBundlePrices();
                    }
                  }

                  // Watch hidden variant input (attribute + value change)
                  var productForm = document.getElementById('{{ product_form_id }}');
                  if (productForm) {
                    var variantInput = productForm.querySelector('input[name="id"]');
                    if (variantInput) {
                      new MutationObserver(function() {
                        handleVariantChange(variantInput.value);
                      }).observe(variantInput, { attributes: true, attributeFilter: ['value'] });
                      variantInput.addEventListener('change', function() {
                        handleVariantChange(this.value);
                      });
                    }
                  }

                  // Variant custom element events
                  ['variant-dropdown', 'variant-pills'].forEach(function(tag) {
                    var el = document.querySelector(tag);
                    if (!el) return;
                    ['change', 'variant:changed', 'on:variant:change'].forEach(function(evt) {
                      el.addEventListener(evt, function(e) {
                        var id = (e.detail && (e.detail.variant && e.detail.variant.id || e.detail.id)) || e.target.value;
                        if (id) handleVariantChange(id);
                      });
                    });
                  });
                  ['variant:changed', 'on:variant:change'].forEach(function(evt) {
                    document.addEventListener(evt, function(e) {
                      var id = e.detail && (e.detail.variant && e.detail.variant.id || e.detail.id);
                      if (id) handleVariantChange(id);
                    });
                  });

                  // Polling fallback
                  var lastVariantId = {{ product.selected_or_first_available_variant.id }};
                  setInterval(function() {
                    var form = document.getElementById('{{ product_form_id }}');
                    if (!form) return;
                    var inp = form.querySelector('input[name="id"]');
                    if (!inp) return;
                    var cur = parseInt(inp.value);
                    if (cur && cur !== lastVariantId) {
                      lastVariantId = cur;
                      handleVariantChange(cur);
                    }
                  }, 300);

                  // Bundle click handler
                  bundleOptions.forEach(function(option, index) {
                    option.addEventListener('click', function() {
                      bundleOptions.forEach(function(o) { o.classList.remove('selected'); });
                      option.classList.add('selected');
                      setQuantity(bundleConfig[index].quantity);
                    });
                  });

                  // Init
                  updateBundlePrices();
                });
                </script>
