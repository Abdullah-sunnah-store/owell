                <script>
                  (function() {
                    const bundleSelector = document.getElementById('bundle-selector-{{ block.id }}');
                    const bundleOptions = bundleSelector.querySelectorAll('.bundle-option-{{ block.id }}');
                    
                    // Get variant info from main product form instead of hidden selector
                    const mainVariantSelector = document.querySelector('select[name="id"]') || document.querySelector('input[name="id"]:checked') || document.querySelector('input[name="id"]');
                    
                    // Bundle configuration from Liquid settings
                    const bundleConfig = [
                      {
                        quantity: {{ block.settings.bundle_1_quantity }},
                        discount: {{ block.settings.bundle_1_discount | default: 0 }},
                        fixedPrice: {% if block.settings.bundle_1_price != blank %}{{ block.settings.bundle_1_price }}{% else %}null{% endif %},
                        fixedComparePrice: {% if block.settings.bundle_1_compare_price != blank %}{{ block.settings.bundle_1_compare_price }}{% else %}null{% endif %}
                      },
                      {
                        quantity: {{ block.settings.bundle_2_quantity }},
                        discount: {{ block.settings.bundle_2_discount | default: 33 }},
                        fixedPrice: {% if block.settings.bundle_2_price != blank %}{{ block.settings.bundle_2_price }}{% else %}null{% endif %},
                        fixedComparePrice: {% if block.settings.bundle_2_compare_price != blank %}{{ block.settings.bundle_2_compare_price }}{% else %}null{% endif %}
                      },
                      {
                        quantity: {{ block.settings.bundle_3_quantity }},
                        discount: {{ block.settings.bundle_3_discount | default: 40 }},
                        fixedPrice: {% if block.settings.bundle_3_price != blank %}{{ block.settings.bundle_3_price }}{% else %}null{% endif %},
                        fixedComparePrice: {% if block.settings.bundle_3_compare_price != blank %}{{ block.settings.bundle_3_compare_price }}{% else %}null{% endif %}
                      }
                    ];
                    
                    let selectedQuantity = {{ block.settings.bundle_1_quantity }};
                    let selectedVariantId = mainVariantSelector ? mainVariantSelector.value : {{ product.selected_or_first_available_variant.id }};
                    let selectedVariantPrice = {{ product.selected_or_first_available_variant.price }};
                    
                    // Shopify money format helper
                    function formatMoney(cents) {
                      if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
                        return Shopify.formatMoney(cents, {{ shop.money_format | json }});
                      }
                      
                      // Fallback formatting
                      const dollars = (cents / 100).toFixed(2);
                      return '$' + dollars;
                    }
                    
                    // Update bundle prices based on selected variant
                    function updateBundlePrices() {
                      bundleOptions.forEach((option, index) => {
                        const config = bundleConfig[index];
                        const priceElement = option.querySelector('[data-bundle-price]');
                        const comparePriceElement = option.querySelector('[data-bundle-compare]');
                        
                        if (!priceElement) return;
                        
                        // Use fixed price if set, otherwise calculate dynamically
                        if (config.fixedPrice !== null) {
                          // FIXED PRICING MODE
                          const fixedPriceCents = Math.round(parseFloat(config.fixedPrice) * 100);
                          priceElement.textContent = formatMoney(fixedPriceCents);
                          
                          if (comparePriceElement && config.fixedComparePrice !== null) {
                            const fixedCompareCents = Math.round(parseFloat(config.fixedComparePrice) * 100);
                            comparePriceElement.textContent = formatMoney(fixedCompareCents);
                            comparePriceElement.style.display = 'block';
                          } else if (comparePriceElement) {
                            comparePriceElement.style.display = 'none';
                          }
                        } else {
                          // DYNAMIC PRICING MODE
                          const quantity = config.quantity;
                          const discount = config.discount;
                          
                          // Calculate bundle price (variant price × quantity)
                          const fullBundlePrice = selectedVariantPrice * quantity;
                          
                          // Calculate discounted price
                          const discountedPrice = Math.round(fullBundlePrice * (1 - (discount / 100)));
                          
                          // Update price display
                          priceElement.textContent = formatMoney(discountedPrice);
                          
                          // Show compare price if there's a discount
                          if (comparePriceElement) {
                            if (discount > 0) {
                              comparePriceElement.textContent = formatMoney(fullBundlePrice);
                              comparePriceElement.style.display = 'block';
                            } else {
                              comparePriceElement.style.display = 'none';
                            }
                          }
                        }
                      });
                    }
                    
                    // Handle bundle selection
                    bundleOptions.forEach((option, index) => {
                      option.addEventListener('click', function() {
                        // Remove selected class from all options
                        bundleOptions.forEach(opt => opt.classList.remove('selected'));
                        
                        // Add selected class to clicked option
                        this.classList.add('selected');
                        
                        // Get quantity
                        selectedQuantity = bundleConfig[index].quantity;
                        
                        // Update quantity selector if exists
                        updateQuantitySelector();
                        
                        console.log('Bundle selected:', { 
                          bundleIndex: index,
                          quantity: selectedQuantity,
                          variantId: selectedVariantId,
                          variantPrice: selectedVariantPrice
                        });
                      });
                    });

                    // Listen to main variant selector changes (if it exists)
                    if (mainVariantSelector) {
                      // Handle variant selection from main product form
                      mainVariantSelector.addEventListener('change', function() {
                        selectedVariantId = this.value;
                        
                        // Get price from variant - check if it's a select or radio
                        if (this.tagName === 'SELECT') {
                          const option = this.options[this.selectedIndex];
                          selectedVariantPrice = parseInt(option.dataset.price || option.getAttribute('data-price') || {{ product.selected_or_first_available_variant.price }});
                        } else {
                          // For radio buttons, find the corresponding variant price
                          const variantId = parseInt(this.value);
                          {% for variant in product.variants %}
                            if (variantId === {{ variant.id }}) {
                              selectedVariantPrice = {{ variant.price }};
                            }
                          {% endfor %}
                        }
                        
                        // Update bundle prices
                        updateBundlePrices();
                        
                        console.log('Main variant changed:', { 
                          variantId: selectedVariantId,
                          variantPrice: selectedVariantPrice,
                          quantity: selectedQuantity 
                        });
                      });
                      
                      // Also listen to radio button changes if pills style is used
                      document.querySelectorAll('input[name="id"]').forEach(radio => {
                        radio.addEventListener('change', function() {
                          if (this.checked) {
                            selectedVariantId = this.value;
                            const variantId = parseInt(this.value);
                            {% for variant in product.variants %}
                              if (variantId === {{ variant.id }}) {
                                selectedVariantPrice = {{ variant.price }};
                              }
                            {% endfor %}
                            updateBundlePrices();
                          }
                        });
                      });
                    }

                    function updateQuantitySelector() {
                      const quantityInput = document.querySelector('input[name="quantity"]');
                      if (quantityInput) {
                        quantityInput.value = selectedQuantity;
                        
                        // Trigger change event to update price displays
                        const event = new Event('change', { bubbles: true });
                        quantityInput.dispatchEvent(event);
                      }
                    }
                    
                    // Initialize bundle prices on load
                    updateBundlePrices();

                    // Store bundle data for form submission
                    window.bundleData_{{ block.id }} = {
                      getSelectedVariant: () => selectedVariantId,
                      getSelectedQuantity: () => selectedQuantity,
                      getSelectedVariantPrice: () => selectedVariantPrice
                    };
                  })();
                </script>
