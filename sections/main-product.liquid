{% comment %} Only Render Video styles if video media are present {% endcomment %}
{%- if media_type_video > 0 or media_type_external_video > 0 -%}
  {{ 'section-video.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{{ 'section-product-highlights.css' | asset_url | stylesheet_tag }}

{% comment %} Render Model Viewer Ui css to style buttons and zoom {% endcomment %}
{%- if first_3d_model -%}
  <link
    href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
    id="ModelViewerStyle"
    media="print"
    onload="this.media='all'"
    rel="stylesheet"
  >
{%- endif -%}
{% unless section.settings.border_size == 'hide' %}
  {% if section.settings.border_position == 'both' or section.settings.border_position == 'top' %}
    {% unless section.settings.border_size == 'full_width' %}
      <div class="container">
    {% endunless %}
    <div class="spacer-wrapper color-{{ section.settings.color_scheme }}">
      <div
        class="spacer border-top"
      ></div>
    </div>
    {% unless section.settings.border_size == 'full_width' %}
      </div>
    {% endunless %}
  {% endif %}
{% endunless %}
<div
  class="main-product feature-product section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} "
  data-section-id="{{ section.id }}"
  {% if enable_media_zoom %}
    style="--cursor-zoom-url:url({{ 'zoom-cursor.svg' | asset_url }})"
  {% endif %}
>
  <div class="container">
    {% render 'breadcrumb' %}
    <div
      product-container
      class="{% if section.settings.desktop_media_position == 'right' %} flex-reverse {% else %} res-flex {% endif %} {% if layout_type == 'grid' or layout_type == 'grid-with-main-media' %} sticky-content {% endif %}"
    >
      {% if product_media.size > 0 %}
        <div class="product-media-container product-media-container--{{ section.settings.desktop_media_size }}">
          {% liquid
            if section.settings.image_aspect_ratio_desktop == 'adapt'
              assign add_media_aspect_ratio = true
            else
              assign add_media_aspect_ratio = false
            endif

            if section.settings.image_aspect_ratio_mobile == 'adapt'
              assign add_media_aspect_ratio_mobile = true
            else
              assign add_media_aspect_ratio_mobile = false
            endif
          %}
          <product-carousel
            {{ intersection }}
            class="js-element product-slider--{{ section.settings.display_options_layout }}  {% if layout_type == 'grid' or layout_type == 'grid-with-main-media' %} mobile-only {% endif %}"
            slide-layout-type="carousel"
            slide-pagination-type="bullets"
            slide-per-view="1"
            slide-responsive-breakpoints='{"320":{"slidesPerView": "1","autoHeight":{{ add_media_aspect_ratio_mobile }} },"640":{"slidesPerView":"1","autoHeight": {{ add_media_aspect_ratio }}}}'
            slide-speed="500"
            verticle-thumbnail="{% if section.settings.display_options_layout == 'thumbnail-left' %}true{% else %}false{% endif %}"
            {%- if media_autoplay -%}
              slide-media-autoplay
            {%- endif -%}
            {%- if product_feature_media_id -%}
              slide-to-media="{{ product_feature_media_id | escape }}"
            {%- endif -%}
          >
            <div
              class="swiper"
            >
              <div
                class="swiper-container product-main-slide-container {% unless add_media_aspect_ratio %} aspect-ratio-{{ section.settings.image_aspect_ratio_desktop }} {% endunless %} {% unless add_media_aspect_ratio_mobile %} aspect-ratio-mobile-{{ section.settings.image_aspect_ratio_mobile }} {% endunless %}"
                main-slider
              >
                <div class="swiper-wrapper">
                  <div class="swiper-slide">
                    {%- if enable_media_zoom and product_first_media.media_type == 'image' -%}
                      <product-zoom class="icon-product-zoom" data-index="{% increment i %}">
                        {%- render 'icon', icon: 'product-zoom' -%}
                      </product-zoom>
                    {%- endif -%}
                    {% render 'media',
                      media: product_first_media,
                      show_preview_image: false,
                      media_autoplay: media_autoplay,
                      media_custom_identifier: 'carousel',
                      add_media_aspect_ratio: add_media_aspect_ratio,
                      add_media_aspect_ratio_mobile: add_media_aspect_ratio_mobile,
                      section: section
                    %}
                  </div>
                  {% for media in medias %}
{%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop Start {%- endcomment -%}
{%- capture hide_resource -%}{% render "orbit_wholesale_product_visibility", resource: media %}{%- endcapture -%}
{%- if hide_resource == "true" -%}
  {% continue %}
{%- endif -%}
{%- comment -%} Wholesale_Hub_Product_Visibility_For_Loop End {%- endcomment -%}

                    {% if media.id != product_feature_media_id %}
                      <div class="swiper-slide">
                        {%- if enable_media_zoom and media.media_type == 'image' -%}
                          <product-zoom class="icon-product-zoom" data-index="{% increment i %}">
                            {%- render 'icon', icon: 'product-zoom' -%}
                          </product-zoom>
                        {%- endif -%}
                        {% render 'media',
                          media: media,
                          show_preview_image: false,
                          media_autoplay: media_autoplay,
                          forloop: forloop,
                          media_custom_identifier: 'carousel',
                          add_media_aspect_ratio: add_media_aspect_ratio,
                          add_media_aspect_ratio_mobile: add_media_aspect_ratio_mobile,
                          section: section
                        %}
                        {%- if media.media_type == 'model' -%}
                          <button
                            aria-label="{{ 'products.product.xr_button' | t }}"
                            class="btn product__xr-button"
                            data-first-model-id="{{ media.id }}"
                            data-shopify-model3d-id="{{ media.id }}"
                            data-shopify-title="{{ product.title | escape }}"
                            data-shopify-xr
                            data-shopify-xr-hidden
                            shopify-xr-button
                            type="button"
                          >
                            <span class="btn__icon">
                              {% render 'icon' with '3d-model' %}
                            </span>
                            <span class="btn__text">
                              {{ 'products.product.xr_button' | t }}
                            </span>
                          </button>
                        {%- endif -%}
                      </div>
                    {% endif %}
                  {% endfor %}
                </div>
                {% unless section.settings.slider_hide_arrows %}
                  <div class="sliderControl d-flex ">
                    <!-- next / prev arrows Starts -->
                    <div class=" slider-arrow" slide-prev>
                      <div class="sliderPagination__prev">
                        {% render 'slider-arrow-icon', arrow_direction: 'left' %}
                      </div>
                    </div>
                    <div class=" slider-arrow" slide-next>
                      <div class="sliderPagination__next">
                        {% render 'slider-arrow-icon', arrow_direction: 'right' %}
                      </div>
                    </div>

                    <!-- !next / prev arrows Ends -->
                  </div>
                {% endunless %}
              </div>
            </div>
            {% comment %}
              {%- if first_3d_model -%}
                <button
                  aria-label="{{ 'products.product.xr_button' | t }}"
                  class="btn product__xr-button"
                  data-first-model-id="{{ first_3d_model.id }}"
                  data-shopify-model3d-id="{{ first_3d_model.id }}"
                  data-shopify-title="{{ product.title | escape }}"
                  data-shopify-xr
                  data-shopify-xr-hidden
                  shopify-xr-button
                  type="button"
                >
                  <span class="btn__icon">
                    {% render 'icon' with '3d-model' %}
                  </span>
                  <span class="btn__text">
                    {{ 'products.product.xr_button' | t }}
                  </span>
                </button>
              {%- endif -%}
            {% endcomment %}
             
            {% if product_media.size > 1 %}
              <div class="sliderControl has-thumbnail-slider">
                {% comment %} <div class="sliderProgressBar" slide-progress></div> {% endcomment %}
                <div class="swiper-thumbnails{% if section.settings.slider_hide_arrows %} no-arrows {% endif %}">
                  <div class="swiper">
                    <div class="swiper-container" thumbnail-slider>
                      <div class="swiper-wrapper">
                        {% render 'product-media',
                          product_media: product_media,
                          render_preview_image: true,
                          product_first_media: product_first_media,
                          product_feature_media_id: product_feature_media_id
                        %}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            {% endif %}
          {%- comment -%} Dynamic feature icons — directly under product images {%- endcomment -%}
          {%- assign _fi_block = nil -%}
          {%- for _b in section.blocks -%}
            {%- if _b.type == 'feature_icons' -%}
              {%- assign _fi_block = _b -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if _fi_block != nil -%}
            {%- render 'product-feature-icons', product: product, block: _fi_block -%}
          {%- endif -%}
          </product-carousel>
          <noscript>
            {%- assign firstMedia = product.selected_or_first_available_variant.feature_image -%}
            {%- if firstMedia == blank -%}
              {%- assign firstMedia = product_media | where: 'media_type', 'image' | first -%}
            {%- endif -%}

            {% comment %} product.selected_or_first_available_variant.featured_media | default: medias | first {% endcomment %}
            <product-carousel class="carousel-active product-slider--{{ section.settings.display_options_layout }}  {% if layout_type == 'grid' or layout_type == 'grid-with-main-media' %} mobile-only {% endif %}">
              <div class="product-main-slide-container">
                {% render 'media', media: firstMedia, media_custom_identifier: 'carousel', section: section %}
              </div>
            </product-carousel>
          </noscript>
          {%- case layout_type -%}
            {%- when 'grid', 'grid-with-main-media' %}
              <div class="grid__layout {{ section.settings.display_options_layout }} desktop-only" product-grid-layout>
                <div
                  class="grid__layout__item position-relative"
                  data-media-target-id="media-{{ product_feature_media_id }}"
                >
                  {%- if enable_media_zoom and product_first_media.media_type == 'image' -%}
                    <product-zoom class="icon-product-zoom" data-index="{% increment j %}">
                      {%- render 'icon', icon: 'product-zoom' -%}
                    </product-zoom>
                  {%- endif -%}
                  {% render 'media',
                    media: product_first_media,
