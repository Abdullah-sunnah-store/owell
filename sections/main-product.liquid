                </div>

                <script>
                (function() {
                  var blockId = '{{ block.id }}';
                  var sectionId = '{{ section.id }}';
                  var discountPct = {{ block.settings.discount_percent }};
                  var moneyFormat = {{ shop.money_format | json }};
                  var isSelected = false;
                  var discountCode = '{{ block.settings.discount_code | escape }}';

                  function formatMoney(cents) {
                    if (window.Shopify && window.Shopify.formatMoney) {
                      return window.Shopify.formatMoney(cents, moneyFormat);
                    }
                    return '$' + (cents / 100).toFixed(2);
                  }

                  function getVariants() {
                    var el = document.querySelector(
                      'variant-dropdown[data-section="' + sectionId + '"] [type="application/json"],' +
                      'variant-pills[data-section="' + sectionId + '"] [type="application/json"]'
                    );
                    if (!el) return [];
                    try { return JSON.parse(el.textContent); } catch(e) { return []; }
                  }

                  function getCurrentVariantPrice() {
                    var form = document.getElementById('product-form-' + sectionId);
                    if (!form) return null;
                    var input = form.querySelector('input[name="id"]');
                    if (!input) return null;
                    var variantId = parseInt(input.value);
                    var variants = getVariants();
                    var variant = variants.find(function(v) { return v.id === variantId; });
                    return variant ? variant.price : null;
                  }

                  function applyDiscount(active) {
                    var priceWrap = document.getElementById('price-' + sectionId);
                    if (!priceWrap) return;
                    var priceEl = priceWrap.querySelector('.price');
                    if (!priceEl) return;

                    if (!active) {
                      if (priceEl.dataset.ssOriginal) {
                        priceEl.innerHTML = priceEl.dataset.ssOriginal;
                        delete priceEl.dataset.ssOriginal;
                      }
                      // Clear discount code from session
                      if (discountCode) {
                        fetch('/discount/?discount=', {credentials: 'same-origin'});
                      }
                      return;
                    }

                    // Already showing discounted price — don't reapply
                    if (priceEl.dataset.ssOriginal) return;

                    var basePrice = getCurrentVariantPrice();
                    if (basePrice === null) return;

                    var discounted = Math.round(basePrice * (1 - discountPct / 100));
                    priceEl.dataset.ssOriginal = priceEl.innerHTML;
                    priceEl.innerHTML = formatMoney(discounted)
                      + ' <del style="opacity:0.55;font-size:0.85em;font-weight:400">'
                      + formatMoney(basePrice) + '</del>';

                    // Apply discount code to Shopify session so it carries to checkout
                    if (discountCode) {
                      fetch('/discount/' + encodeURIComponent(discountCode), {credentials: 'same-origin'});
                    }
                  }

                  document.addEventListener('DOMContentLoaded', function() {
                    var btn = document.getElementById('ss-btn-' + blockId);
                    if (!btn) return;

                    // After variant change the theme re-renders #price-{id} innerHTML.
                    // The new .price element won't have data-ss-original, so re-apply.
                    var priceWrap = document.getElementById('price-' + sectionId);
                    if (priceWrap) {
                      new MutationObserver(function() {
                        if (!isSelected) return;
                        var priceEl = priceWrap.querySelector('.price');
                        // Only re-apply if this is a fresh render (no ssOriginal)
                        if (priceEl && !priceEl.dataset.ssOriginal) {
                          applyDiscount(true);
                        }
                      }).observe(priceWrap, { childList: true, subtree: true });
                    }

                    btn.addEventListener('click', function() {
                      isSelected = !isSelected;
                      btn.setAttribute('aria-pressed', String(isSelected));
                      btn.classList.toggle('selected', isSelected);
                      applyDiscount(isSelected);
                    });
                  });
                })();
                </script>

