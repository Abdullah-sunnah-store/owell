                  }
                </style>

                <div class="bundle-selector-{{ block.id }}" {{ block.shopify_attributes }}>
                  
                  {% comment %}
                  <!-- Variant Selector - HIDDEN -->
                  <div class="bundle-variant-selector-{{ block.id }}" style="display: none;">
                    <label class="bundle-variant-label-{{ block.id }}">
                      Select Variant
                    </label>
                    <select class="bundle-variant-select-{{ block.id }}" id="bundle-variant-{{ block.id }}">
                      {% for variant in product.variants %}
                        <option 
                          value="{{ variant.id }}" 
                          data-price="{{ variant.price }}"
                          {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
