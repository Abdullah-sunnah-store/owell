{{ 'section-account-auth.css' | asset_url | stylesheet_tag }}

{%- comment -%} Capture recover form state before login form renders {%- endcomment -%}
{%- form 'recover_customer_password' -%}
  {%- assign recover_posted = form.posted_successfully? -%}
  {%- assign recover_errors = form.errors -%}
{%- endform -%}

<div class="owell-auth">
  <div class="owell-auth__container">

    {%- comment -%} ── RECOVER PASSWORD PANEL ── {%- endcomment -%}
    <div class="owell-auth__panel" id="owell-recover-panel">

      {%- form 'recover_customer_password' -%}
        <h1 class="owell-auth__title">Reset Password</h1>
        <p class="owell-auth__subtitle">Enter your email and we'll send you a reset link.</p>

        {%- if recover_errors -%}
          <div class="owell-auth__error">{{ recover_errors.messages.form }}</div>
        {%- endif -%}
        {%- if recover_posted -%}
          <div class="owell-auth__success">{{ 'customer.recover_password.success' | t }}</div>
        {%- endif -%}

        <div class="owell-auth__field">
          <label class="owell-auth__label" for="RecoverEmail">Email</label>
          <input
            class="owell-auth__input"
            type="email"
            name="email"
            id="RecoverEmail"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
          >
        </div>

        <button type="submit" class="owell-auth__btn-primary">Send Reset Link</button>
      {%- endform -%}

      <div class="owell-auth__below-form">
        <a href="#" id="owell-back-to-login">← Back to Log In</a>
      </div>
    </div>

    {%- comment -%} ── LOGIN PANEL ── {%- endcomment -%}
    <div class="owell-auth__panel is-active" id="owell-login-panel">

      {%- form 'customer_login', novalidate: 'novalidate' -%}
        <h1 class="owell-auth__title">Account Login</h1>
        <p class="owell-auth__subtitle">Access your orders, subscriptions, and account details.</p>

        {%- if recover_posted -%}
          <div class="owell-auth__success">{{ 'customer.recover_password.success' | t }}</div>
        {%- endif -%}
        {%- if form.posted_successfully? -%}
          <div class="owell-auth__success">{{ 'customer.reset_password.reset_message' | t }}</div>
        {%- elsif form.errors -%}
          <div class="owell-auth__error">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        <div class="owell-auth__field">
          <label class="owell-auth__label" for="CustomerEmail">Email</label>
          <input
            class="owell-auth__input{% if form.errors contains 'form' %} has-error{% endif %}"
            type="email"
            name="customer[email]"
            id="CustomerEmail"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
          >
        </div>

        {%- if form.password_needed -%}
          <div class="owell-auth__field">
            <label class="owell-auth__label" for="CustomerPassword">Password</label>
            <input
              class="owell-auth__input{% if form.errors contains 'form' %} has-error{% endif %}"
              type="password"
              name="customer[password]"
              id="CustomerPassword"
              autocomplete="current-password"
            >
          </div>
        {%- endif -%}

        <div class="owell-auth__forgot">
          <a href="#" id="owell-forgot-link">Forgot Password?</a>
        </div>

        <button type="submit" class="owell-auth__btn-primary">Log In</button>

        {% if section.settings.enable_sign_in_with_shop %}
          <div style="margin-top:16px;">{{ shop | login_button }}</div>
        {% endif %}

      {%- endform -%}

      <div class="owell-auth__divider"></div>

      <p class="owell-auth__new-label">New to OWELL®?</p>
      <a href="{{ routes.account_register_url }}" class="owell-auth__btn-outline">Create Account</a>

      <a href="{{ section.settings.business_account_url | default: '/pages/wholesale' }}" class="owell-auth__business-link">
        For structured pricing and volume purchasing: Open a Business Account →
      </a>

    </div>
  </div>
</div>

<script>
(function() {
  var loginPanel   = document.getElementById('owell-login-panel');
  var recoverPanel = document.getElementById('owell-recover-panel');
  var forgotLink   = document.getElementById('owell-forgot-link');
  var backLink     = document.getElementById('owell-back-to-login');

  function showRecover() {
    loginPanel.classList.remove('is-active');
    recoverPanel.classList.add('is-active');
  }
  function showLogin() {
    recoverPanel.classList.remove('is-active');
    loginPanel.classList.add('is-active');
  }

  if (forgotLink) forgotLink.addEventListener('click', function(e) { e.preventDefault(); showRecover(); });
  if (backLink)   backLink.addEventListener('click',   function(e) { e.preventDefault(); showLogin(); });

  // Support old anchor-based links (e.g. from password reset email)
  if (window.location.hash === '#recover') showRecover();
})();
</script>

{% schema %}
{
  "name": "Customer login",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sign_in_with_shop",
      "label": "Enable Sign in with Shop",
      "default": false
    },
    {
      "type": "url",
      "id": "business_account_url",
      "label": "Business Account page URL"
    }
  ],
  "enabled_on": {
    "templates": ["customers/login"]
  }
}
{% endschema %}
