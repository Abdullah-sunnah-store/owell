      "settings": {
        "section_width": true,
        "custom_liquid": "<style>\n/* ===== Application Form Styling ===== */\n.application-form-wrapper {\n  max-width: 800px;\n  margin: 60px auto;\n  padding: 40px;\n  background: #ffffff;\n  border-radius: 12px;\n  box-shadow: 0 10px 30px rgba(0,0,0,0.06);\n}\n\n/* Progress Steps */\n.progress-steps {\n  display: flex;\n  justify-content: space-between;\n  margin-bottom: 40px;\n  position: relative;\n}\n.progress-steps::before {\n  content: '';\n  position: absolute;\n  top: 20px;\n  left: 25%;\n  right: 25%;\n  height: 2px;\n  background: #ddd;\n  z-index: 0;\n}\n.progress-steps.step-2::before {\n  background: #4a8df6;\n}\n.step-item {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  position: relative;\n  z-index: 1;\n  flex: 1;\n}\n.step-circle {\n  width: 40px;\n  height: 40px;\n  border-radius: 50%;\n  background: #fff;\n  border: 2px solid #ddd;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-weight: 600;\n  color: #999;\n  margin-bottom: 8px;\n  transition: all 0.3s ease;\n}\n.step-item.active .step-circle {\n  background: #4a8df6;\n  border-color: #4a8df6;\n  color: #fff;\n}\n.step-item.completed .step-circle {\n  background: #4a8df6;\n  border-color: #4a8df6;\n  color: #fff;\n}\n.step-label {\n  font-size: 14px;\n  color: #666;\n  font-weight: 500;\n}\n.step-item.active .step-label {\n  color: #4a8df6;\n  font-weight: 600;\n}\n\n/* Form Sections */\n.form-step {\n  display: none;\n}\n.form-step.active {\n  display: block;\n  animation: fadeIn 0.4s ease;\n}\n@keyframes fadeIn {\n  from { opacity: 0; transform: translateY(10px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n\n.application-form-wrapper h2 {\n  font-size: 28px;\n  margin-bottom: 30px;\n  font-weight: 600;\n  color: #111;\n}\n.application-form-wrapper label {\n  display: block;\n  margin-bottom: 6px;\n  font-weight: 500;\n  font-size: 14px;\n  color: #333;\n}\n.application-form-wrapper label.optional {\n  color: #666;\n  font-weight: 400;\n}\n.application-form-wrapper input,\n.application-form-wrapper textarea,\n.application-form-wrapper select {\n  width: 100%;\n  padding: 12px 14px;\n  margin-bottom: 20px;\n  border: 1px solid #ddd;\n  border-radius: 8px;\n  font-size: 14px;\n  transition: all 0.3s ease;\n  font-family: inherit;\n}\n.application-form-wrapper input:focus,\n.application-form-wrapper textarea:focus,\n.application-form-wrapper select:focus {\n  border-color: #4a8df6;\n  outline: none;\n  box-shadow: 0 0 0 3px rgba(74,141,246,0.1);\n}\n.application-row {\n  display: flex;\n  gap: 20px;\n}\n.application-col {\n  flex: 1;\n}\n\n/* Radio Buttons */\n.radio-group {\n  display: flex;\n  gap: 20px;\n  margin-bottom: 20px;\n}\n.radio-option {\n  display: flex;\n  align-items: center;\n  cursor: pointer;\n}\n.radio-option input[type=\"radio\"] {\n  width: 18px;\n  height: 18px;\n  margin: 0 8px 0 0;\n  cursor: pointer;\n}\n\n/* Buttons */\n.form-buttons {\n  display: flex;\n  gap: 15px;\n  margin-top: 30px;\n}\n.btn {\n  flex: 1;\n  padding: 14px;\n  border: none;\n  border-radius: 8px;\n  font-size: 15px;\n  font-weight: 600;\n  cursor: pointer;\n  transition: all 0.3s ease;\n}\n.btn-primary {\n  background: #4a8df6;\n  color: #fff;\n}\n.btn-primary:hover {\n  background: #3a75d6;\n}\n.btn-secondary {\n  background: #f5f5f5;\n  color: #333;\n}\n.btn-secondary:hover {\n  background: #e5e5e5;\n}\n\n/* Success Message */\n.application-success {\n  text-align: center;\n  display: none;\n}\n.application-success.active {\n  display: block;\n  animation: fadeIn 0.4s ease;\n}\n.success-icon {\n  width: 80px;\n  height: 80px;\n  background: #e6f4ea;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 40px;\n  margin: 0 auto 20px;\n}\n.application-success h2 {\n  color: #1e7e34;\n  margin-bottom: 15px;\n}\n.application-success p {\n  color: #666;\n  font-size: 16px;\n  line-height: 1.6;\n  margin-bottom: 30px;\n}\n.success-buttons {\n  display: flex;\n  gap: 15px;\n  margin-top: 30px;\n}\n.success-buttons a {\n  flex: 1;\n  padding: 14px 20px;\n  text-align: center;\n  text-decoration: none;\n  border-radius: 8px;\n  font-size: 15px;\n  font-weight: 600;\n  transition: all 0.3s ease;\n}\n.btn-shop {\n  background: #4a8df6;\n  color: #fff;\n}\n.btn-shop:hover {\n  background: #3a75d6;\n  transform: translateY(-2px);\n  box-shadow: 0 4px 12px rgba(74,141,246,0.3);\n}\n.btn-sample {\n  background: #fff;\n  color: #4a8df6;\n  border: 2px solid #4a8df6;\n}\n.btn-sample:hover {\n  background: #f0f7ff;\n  transform: translateY(-2px);\n  box-shadow: 0 4px 12px rgba(74,141,246,0.2);\n}\n\n@media (max-width: 768px) {\n  .application-form-wrapper {\n    padding: 30px 20px;\n  }\n  .application-row {\n    flex-direction: column;\n  }\n  .success-buttons {\n    flex-direction: column;\n  }\n  .form-buttons {\n    flex-direction: column;\n  }\n}\n</style>\n\n<div class=\"application-form-wrapper\">\n  <!-- Progress Steps -->\n  <div class=\"progress-steps\" id=\"progressSteps\">\n    <div class=\"step-item active\" data-step=\"1\">\n      <div class=\"step-circle\">1</div>\n      <span class=\"step-label\">Business Info</span>\n    </div>\n    <div class=\"step-item\" data-step=\"2\">\n      <div class=\"step-circle\">2</div>\n      <span class=\"step-label\">Legal Details</span>\n    </div>\n  </div>\n\n  <form id=\"applicationForm\">\n    <!-- Step 1: Business Information -->\n    <div class=\"form-step active\" id=\"step1\">\n      <h2>Business Information</h2>\n      \n      <label>Business Name *</label>\n      <input type=\"text\" name=\"business_name\" required>\n      \n      <label>Business Email Address *</label>\n      <input type=\"email\" name=\"business_email\" required>\n      \n      <label>Phone Number *</label>\n      <input type=\"tel\" name=\"phone\" required>\n      \n      <label>Business Type *</label>\n      <select name=\"business_type\" required>\n        <option value=\"\">Select your business type</option>\n        <option value=\"Medical / Dental\">Medical / Dental</option>\n        <option value=\"Food Service / Hospitality\">Food Service / Hospitality</option>\n        <option value=\"Janitorial / Facility\">Janitorial / Facility</option>\n        <option value=\"Retail\">Retail</option>\n        <option value=\"Laboratory / Drug Testing\">Laboratory / Drug Testing</option>\n        <option value=\"Other\">Other</option>\n      </select>\n      \n      <label>How Often Do You Order Supplies? *</label>\n      <select name=\"order_frequency\" required>\n        <option value=\"\">Select frequency</option>\n        <option value=\"Weekly\">Weekly</option>\n        <option value=\"Bi-Weekly\">Bi-Weekly</option>\n        <option value=\"Monthly\">Monthly</option>\n        <option value=\"Quarterly\">Quarterly</option>\n        <option value=\"As Needed\">As Needed</option>\n      </select>\n      \n      <label class=\"optional\">How did you hear about us? (Optional)</label>\n      <input type=\"text\" name=\"referral\">\n      \n      <div class=\"form-buttons\">\n        <button type=\"button\" class=\"btn btn-primary\" onclick=\"goToStep2()\">Next →</button>\n      </div>\n    </div>\n\n    <!-- Step 2: Legal Details -->\n    <div class=\"form-step\" id=\"step2\">\n      <h2>Legal & Shipping Details</h2>\n      \n      <label>Legal Business Name *</label>\n      <input type=\"text\" name=\"legal_business_name\" required>\n      \n      <label>Tax ID / EIN *</label>\n      <input type=\"text\" name=\"tax_id\" required placeholder=\"XX-XXXXXXX\">\n      \n      <label>Shipping Address (physical address only — no PO Boxes) *</label>\n      <input type=\"text\" name=\"shipping_address\" required>\n      \n      <div class=\"application-row\">\n        <div class=\"application-col\">\n          <label>City *</label>\n          <input type=\"text\" name=\"city\" required>\n        </div>\n        <div class=\"application-col\">\n          <label>State / Province *</label>\n          <input type=\"text\" name=\"state\" required>\n        </div>\n        <div class=\"application-col\">\n          <label>ZIP / Postal Code *</label>\n          <input type=\"text\" name=\"zip\" required>\n        </div>\n      </div>\n      \n      <label>Is this a commercial location? *</label>\n      <div class=\"radio-group\">\n        <label class=\"radio-option\">\n          <input type=\"radio\" name=\"commercial_location\" value=\"Yes\" required>\n          Yes\n        </label>\n        <label class=\"radio-option\">\n          <input type=\"radio\" name=\"commercial_location\" value=\"No\" required>\n          No\n        </label>\n      </div>\n      \n      <label>Loading Dock Available? *</label>\n      <div class=\"radio-group\">\n        <label class=\"radio-option\">\n          <input type=\"radio\" name=\"loading_dock\" value=\"Yes\" required>\n          Yes\n        </label>\n        <label class=\"radio-option\">\n          <input type=\"radio\" name=\"loading_dock\" value=\"No\" required>\n          No\n        </label>\n      </div>\n      \n      <label>Business Hours *</label>\n      <input type=\"text\" name=\"business_hours\" required placeholder=\"e.g., Mon-Fri 9AM-5PM\">\n      \n      <label class=\"optional\">Notes / Special Instructions (Optional)</label>\n      <textarea name=\"notes\" rows=\"4\"></textarea>\n      \n      <div class=\"form-buttons\">\n        <button type=\"button\" class=\"btn btn-secondary\" onclick=\"goToStep1()\">← Back</button>\n        <button type=\"submit\" class=\"btn btn-primary\">Submit Application</button>\n      </div>\n    </div>\n  </form>\n\n  <!-- Success Message -->\n  <div class=\"application-success\" id=\"successMessage\">\n    <div class=\"success-icon\">✓</div>\n    <h2>Thank You for Applying!</h2>\n    <p>\n      Our team will review your application and follow up shortly.<br>\n      <strong>Most business accounts are approved within one business day.</strong>\n    </p>\n    <div class=\"success-buttons\">\n      <a href=\"https://owell.com/collections/owell-disposable-gloves\" class=\"btn-shop\">\n         Shop Gloves\n      </a>\n      <a href=\"https://owell.com/pages/owell-wholesale-bulk-purchasing\" class=\"btn-sample\">\n         Request Free Sample\n      </a>\n    </div>\n  </div>\n</div>\n\n<script>\nfunction goToStep2() {\n  // Validate Step 1 fields\n  const step1 = document.getElementById('step1');\n  const requiredFields = step1.querySelectorAll('[required]');\n  let allValid = true;\n  \n  requiredFields.forEach(field => {\n    if (!field.value.trim()) {\n      allValid = false;\n      field.style.borderColor = '#c62828';\n    } else {\n      field.style.borderColor = '#ddd';\n    }\n  });\n  \n  if (!allValid) {\n    alert('Please fill in all required fields');\n    return;\n  }\n  \n  // Move to Step 2\n  document.getElementById('step1').classList.remove('active');\n  document.getElementById('step2').classList.add('active');\n  \n  // Update progress\n  document.querySelector('[data-step=\"1\"]').classList.add('completed');\n  document.querySelector('[data-step=\"1\"]').classList.remove('active');\n  document.querySelector('[data-step=\"2\"]').classList.add('active');\n  document.getElementById('progressSteps').classList.add('step-2');\n  \n  // Scroll to top\n  document.querySelector('.application-form-wrapper').scrollIntoView({ behavior: 'smooth' });\n}\n\nfunction goToStep1() {\n  // Move back to Step 1\n  document.getElementById('step2').classList.remove('active');\n  document.getElementById('step1').classList.add('active');\n  \n  // Update progress\n  document.querySelector('[data-step=\"1\"]').classList.remove('completed');\n  document.querySelector('[data-step=\"1\"]').classList.add('active');\n  document.querySelector('[data-step=\"2\"]').classList.remove('active');\n  document.getElementById('progressSteps').classList.remove('step-2');\n  \n  // Scroll to top\n  document.querySelector('.application-form-wrapper').scrollIntoView({ behavior: 'smooth' });\n}\n\ndocument.getElementById('applicationForm').addEventListener('submit', function(e) {\n  e.preventDefault();\n  \n  // Here you would normally send the form data to your server\n  // For now, we'll just show the success message\n  \n  // Hide the form\n  document.getElementById('progressSteps').style.display = 'none';\n  document.getElementById('step2').style.display = 'none';\n  \n  // Show success message\n  document.getElementById('successMessage').classList.add('active');\n  \n  // Scroll to top\n  document.querySelector('.application-form-wrapper').scrollIntoView({ behavior: 'smooth' });\n});\n</script>",
