: 60px auto;\n  padding: 40px;\n  background: #ffffff;\n  border-radius: 12px;\n  box-shadow: 0 10px 30px rgba(0,0,0,0.06);\n}\n\n\/* Progress Steps *\/\n.progress-steps {\n  display: flex;\n  justify-content: space-between;\n  margin-bottom: 40px;\n  position: relative;\n}\n.progress-steps::before {\n  content: '';\n  position: absolute;\n  top: 20px;\n  left: 25%;\n  right: 25%;\n  height: 2px;\n  background: #ddd;\n  z-index: 0;\n}\n.progress-steps.step-2::before {\n  background: #4a8df6;\n}\n.step-item {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  position: relative;\n  z-index: 1;\n  flex: 1;\n}\n.step-circle {\n  width: 40px;\n  height: 40px;\n  border-radius: 50%;\n  background: #fff;\n  border: 2px solid #ddd;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-weight: 600;\n  color: #999;\n  margin-bottom: 8px;\n  transition: all 0.3s ease;\n}\n.step-item.active .step-circle {\n  background: #4a8df6;\n  border-color: #4a8df6;\n  color: #fff;\n}\n.step-item.completed .step-circle {\n  background: #4a8df6;\n  border-color: #4a8df6;\n  color: #fff;\n}\n.step-label {\n  font-size: 14px;\n  color: #666;\n  font-weight: 500;\n}\n.step-item.active .step-label {\n  color: #4a8df6;\n  font-weight: 600;\n}\n\n\/* Form Sections *\/\n.form-step {\n  display: none;\n}\n.form-step.active {\n  display: block;\n  animation: fadeIn 0.4s ease;\n}\n@keyframes fadeIn {\n  from { opacity: 0; transform: translateY(10px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n\n.application-form-wrapper h2 {\n  font-size: 28px;\n  margin-bottom: 30px;\n  font-weight: 600;\n  color: #111;\n}\n.application-form-wrapper label {\n  display: block;\n  margin-bottom: 6px;\n  font-weight: 500;\n  font-size: 14px;\n  color: #333;\n}\n.application-form-wrapper label.optional {\n  color: #666;\n  font-weight: 400;\n}\n.application-form-wrapper input,\n.application-form-wrapper textarea,\n.application-form-wrapper select {\n  width: 100%;\n  padding: 12px 14px;\n  margin-bottom: 20px;\n  border: 1px solid #ddd;\n  border-radius: 8px;\n  font-size: 14px;\n  transition: all 0.3s ease;\n  font-family: inherit;\n}\n.application-form-wrapper input:focus,\n.application-form-wrapper textarea:focus,\n.application-form-wrapper select:focus {\n  border-color: #4a8df6;\n  outline: none;\n  box-shadow: 0 0 0 3px rgba(74,141,246,0.1);\n}\n.application-row {\n  display: flex;\n  gap: 20px;\n}\n.application-col {\n  flex: 1;\n}\n\n\/* Radio Buttons *\/\n.radio-group {\n  display: flex;\n  gap: 20px;\n  margin-bottom: 20px;\n}\n.radio-option {\n  display: flex;\n  align-items: center;\n  cursor: pointer;\n}\n.radio-option input[type=\"radio\"] {\n  width: 18px;\n  height: 18px;\n  margin: 0 8px 0 0;\n  cursor: pointer;\n}\n\n\/* Buttons *\/\n.form-buttons {\n  display: flex;\n  gap: 15px;\n  margin-top: 30px;\n}\n.btn {\n  flex: 1;\n  padding: 14px;\n  border: none;\n  border-radius: 8px;\n  font-size: 15px;\n  font-weight: 600;\n  cursor: pointer;\n  transition: all 0.3s ease;\n}\n.btn-primary {\n  background: #4a8df6;\n  color: #fff;\n}\n.btn-primary:hover {\n  background: #3a75d6;\n}\n.btn-secondary {\n  background: #f5f5f5;\n  color: #333;\n}\n.btn-secondary:hover {\n  background: #e5e5e5;\n}\n\n\/* Success Message *\/\n.application-success {\n  text-align: center;\n  display: none;\n}\n.application-success.active {\n  display: block;\n  animation: fadeIn 0.4s ease;\n}\n.success-icon {\n  width: 80px;\n  height: 80px;\n  background: #e6f4ea;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 40px;\n  margin: 0 auto 20px;\n}\n.application-success h2 {\n  color: #1e7e34;\n  margin-bottom: 15px;\n}\n.application-success p {\n  color: #666;\n  font-size: 16px;\n  line-height: 1.6;\n  margin-bottom: 30px;\n}\n.success-buttons {\n  display: flex;\n  gap: 15px;\n  margin-top: 30px;\n}\n.success-buttons a {\n  flex: 1;\n  padding: 14px 20px;\n  text-align: center;\n  text-decoration: none;\n  border-radius: 8px;\n  font-size: 15px;\n  font-weight: 600;\n  transition: all 0.3s ease;\n}\n.btn-shop {\n  background: #4a8df6;\n  color: #fff;\n}\n.btn-shop:hover {\n  background: #3a75d6;\n  transform: translateY(-2px);\n  box-shadow: 0 4px 12px rgba(74,141,246,0.3);\n}\n.btn-sample {\n  background: #fff;\n  color: #4a8df6;\n  border: 2px solid #4a8df6;\n}\n.btn-sample:hover {\n  background: #f0f7ff;\n  transform: translateY(-2px);\n  box-shadow: 0 4px 12px rgba(74,141,246,0.2);\n}\n\n@media (max-width: 768px) {\n  .application-form-wrapper {\n    padding: 30px 20px;\n  }\n  .application-row {\n    flex-direction: column;\n  }\n  .success-buttons {\n    flex-direction: column;\n  }\n  .form-buttons {\n    flex-direction: column;\n  }\n}\n<\/style>\n\n<div class=\"application-form-wrapper\">\n  <!-- Progress Steps -->\n  <div class=\"progress-steps\" id=\"progressSteps\">\n    <div class=\"step-item active\" data-step=\"1\">\n      <div class=\"step-circle\">1<\/div>\n      <span class=\"step-label\">Business Info<\/span>\n    <\/div>\n    <div class=\"step-item\" data-step=\"2\">\n      <div class=\"step-circle\">2<\/div>\n      <span class=\"step-label\">Legal Details<\/span>\n    <\/div>\n  <\/div>\n\n  <form id=\"applicationForm\">\n    <!-- Step 1: Business Information -->\n    <div class=\"form-step active\" id=\"step1\">\n      <h2>Business Information<\/h2>\n      \n      <label>Business Name *<\/label>\n      <input type=\"text\" name=\"business_name\" required>\n      \n      <label>Business Email Address *<\/label>\n      <input type=\"email\" name=\"business_email\" required>\n      \n      <label>Phone Number *<\/label>\n      <input type=\"tel\" name=\"phone\" required>\n      \n      <label>Business Type *<\/label>\n      <select name=\"business_type\" required>\n        <option value=\"\">Select your business type<\/option>\n        <option value=\"Medical \/ Dental\">Medical \/ Dental<\/option>\n        <option value=\"Food Service \/ Hospitality\">Food Service \/ Hospitality<\/option>\n        <option value=\"Janitorial \/ Facility\">Janitorial \/ Facility<\/option>\n        <option value=\"Retail\">Retail<\/option>\n        <option value=\"Laboratory \/ Drug Testing\">Laboratory \/ Drug Testing<\/option>\n        <option value=\"Other\">Other<\/option>\n      <\/select>\n      \n      <label>How Often Do You Order Supplies? *<\/label>\n      <select name=\"order_frequency\" required>\n        <option value=\"\">Select frequency<\/option>\n        <option value=\"Weekly\">Weekly<\/option>\n        <option value=\"Bi-Weekly\">Bi-Weekly<\/option>\n        <option value=\"Monthly\">Monthly<\/option>\n        <option value=\"Quarterly\">Quarterly<\/option>\n        <option value=\"As Needed\">As Needed<\/option>\n      <\/select>\n      \n      <label class=\"optional\">How did you hear about us? (Optional)<\/label>\n      <input type=\"text\" name=\"referral\">\n      \n      <div class=\"form-buttons\">\n        <button type=\"button\" class=\"btn btn-primary\" onclick=\"goToStep2()\">Next →<\/button>\n      <\/div>\n    <\/div>\n\n    <!-- Step 2: Legal Details -->\n    <div class=\"form-step\" id=\"step2\">\n      <h2>Legal & Shipping Details<\/h2>\n      \n      <label>Legal Business Name *<\/label>\n      <input type=\"text\" name=\"legal_business_name\" required>\n      \n      <label>Tax ID \/ EIN *<\/label>\n      <input type=\"text\" name=\"tax_id\" required placeholder=\"XX-XXXXXXX\">\n      \n      <label>Shipping Address (physical address only — no PO Boxes) *<\/label>\n      <input type=\"text\" name=\"shipping_address\" required>\n      \n      <div class=\"application-row\">\n        <div class=\"application-col\">\n          <label>City *<\/label>\n          <input type=\"text\" name=\"city\" required>\n        <\/div>\n        <div class=\"application-col\">\n          <label>State \/ Province *<\/label>\n          <input type=\"text\" name=\"state\" required>\n        <\/div>\n        <div class=\"application-col\">\n          <label>ZIP \/ Postal Code *<\/label>\n          <input type=\"text\" name=\"zip\" required>\n        <\/div>\n      <\/div>\n      \n      <label>Is this a commercial location? *<\/label>\n      <div class=\"radio-group\">\n        <label class=\"radio-option\">\n          <input type=\"radio\" name=\"commercial_location\" value=\"Yes\" required>\n          Yes\n        <\/label>\n        <label class=\"radio-option\">\n          <input type=\"radio\" name=\"commercial_location\" value=\"No\" required>\n          No\n        <\/label>\n      <\/div>\n      \n      <label>Loading Dock Available? *<\/label>\n      <div class=\"radio-group\">\n        <label class=\"radio-option\">\n          <input type=\"radio\" name=\"loading_dock\" value=\"Yes\" required>\n          Yes\n        <\/label>\n        <label class=\"radio-option\">\n          <input type=\"radio\" name=\"loading_dock\" value=\"No\" required>\n          No\n        <\/label>\n      <\/div>\n      \n      <label>Business Hours *<\/label>\n      <input type=\"text\" name=\"business_hours\" required placeholder=\"e.g., Mon-Fri 9AM-5PM\">\n      \n      <label class=\"optional\">Notes \/ Special Instructions (Optional)<\/label>\n      <textarea name=\"notes\" rows=\"4\"><\/textarea>\n      \n      <div class=\"form-buttons\">\n        <button type=\"button\" class=\"btn btn-secondary\" onclick=\"goToStep1()\">← Back<\/button>\n        <button type=\"submit\" class=\"btn btn-primary\">Submit Application<\/button>\n      <\/div>\n    <\/div>\n  <\/form>\n\n  <!-- Success Message -->\n  <div class=\"application-success\" id=\"successMessage\">\n    <div class=\"success-icon\">✓<\/div>\n    <h2>Thank You for Applying!<\/h2>\n    <p>\n      Our team will review your application and follow up shortly.<br>\n      <strong>Most business accounts are approved within one business day.<\/strong>\n    <\/p>\n    <div class=\"success-buttons\">\n      <a href=\"https:\/\/owell.com\/collections\/owell-disposable-gloves\" class=\"btn-shop\">\n         Shop Gloves\n      <\/a>\n      <a href=\"https:\/\/owell.com\/pages\/owell-wholesale-bulk-purchasing\" class=\"btn-sample\">\n         Request Free Sample\n      <\/a>\n    <\/div>\n  <\/div>\n<\/div>\n\n<script>\nfunction goToStep2() {\n  \/\/ Validate Step 1 fields\n  const step1 = document.getElementById('step1');\n  const requiredFields = step1.querySelectorAll('[required]');\n  let allValid = true;\n  \n  requiredFields.forEach(field => {\n    if (!field.value.trim()) {\n      allValid = false;\n      field.style.borderColor = '#c62828';\n    } else {\n      field.style.borderColor = '#ddd';\n    }\n  });\n  \n  if (!allValid) {\n    alert('Please fill in all required fields');\n    return;\n  }\n  \n  \/\/ Move to Step 2\n  document.getElementById('step1').classList.remove('active');\n  document.getElementById('step2').classList.add('active');\n  \n  \/\/ Update progress\n  document.querySelector('[data-step=\"1\"]').classList.add('completed');\n  document.querySelector('[data-step=\"1\"]').classList.remove('active');\n  document.querySelector('[data-step=\"2\"]').classList.add('active');\n  document.getElementById('progressSteps').classList.add('step-2');\n  \n  \/\/ Scroll to top\n  document.querySelector('.application-form-wrapper').scrollIntoView({ behavior: 'smooth' });\n}\n\nfunction goToStep1() {\n  \/\/ Move back to Step 1\n  document.getElementById('step2').classList.remove('active');\n  document.getElementById('step1').classList.add('active');\n  \n  \/\/ Update progress\n  document.querySelector('[data-step=\"1\"]').classList.remove('completed');\n  document.querySelector('[data-step=\"1\"]').classList.add('active');\n  document.querySelector('[data-step=\"2\"]').classList.remove('active');\n  document.getElementById('progressSteps').classList.remove('step-2');\n  \n  \/\/ Scroll to top\n  document.querySelector('.application-form-wrapper').scrollIntoView({ behavior: 'smooth' });\n}\n\ndocument.getElementById('applicationForm').addEventListener('submit', function(e) {\n  e.preventDefault();\n  \n  \/\/ Here you would normally send the form data to your server\n  \/\/ For now, we'll just show the success message\n  \n  \/\/ Hide the form\n  document.getElementById('progressSteps').style.display = 'none';\n  document.getElementById('step2').style.display = 'none';\n  \n  \/\/ Show success message\n  document.getElementById('successMessage').classList.add('active');\n  \n  \/\/ Scroll to top\n  document.querySelector('.application-form-wrapper').scrollIntoView({ behavior: 'smooth' });\n});\n<\/script>","padding_top":52,"padding_bottom":52,"color_scheme":""}},"wholesale_a8YjcW":{"type":"wholesale","name":"Login","settings":{"enable_sign_in_with_shop":false,"padding_top":36,"padding_bottom":36,"color_scheme":""}},"custom_liquid_yAUgrb":{"type":"custom-liquid","disabled":true,"name":"Custom liquid","settings":{"section_width":true,"custom_liquid":"<style>\n\/* ===== Sample Request Form Styling ===== *\/\n.sample-form-wrapper {\n  max-width: 800px;\n  margin: 0 auto 60px;\n  padding: 40px;\n  background: #ffffff;\n  border-radius: 12px;\n  box-shadow: 0 10px 30px rgba(0,0,0,0.06);\n}\n\n.sample-form-wrapper h2 {\n  font-size: 28px;\n  margin-bottom: 8px;\n  font-weight: 600;\n  color: #111;\n}\n.sample-form-wrapper .form-subtitle {\n  font-size: 14px;\n  color: #666;\n  margin-bottom: 30px;\n}\n\n.sample-form-wrapper label {\n  display: block;\n  margin-bottom: 6px;\n  font-weight: 500;\n  font-size: 14px;\n  color: #333;\n}\n.sample-form-wrapper label.optional {\n  color: #666;\n  font-weight: 400;\n}\n.sample-form-wrapper input,\n.sample-form-wrapper textarea,\n.sample-form-wrapper select {\n  width: 100%;\n  padding: 12px 14px;\n  margin-bottom: 20px;\n  border: 1px solid #ddd;\n  border-radius: 8px;\n  font-size: 14px;\n  transition: all 0.3s ease;\n  font-family: inherit;\n  box-sizing: border-box;\n}\n.sample-form-wrapper input:focus,\n.sample-form-wrapper textarea:focus,\n.sample-form-wrapper select:focus {\n  border-color: #4a8df6;\n  outline: none;\n  box-shadow: 0 0 0 3px rgba(74,141,246,0.1);\n}\n.sample-form-wrapper input.field-error,\n.sample-form-wrapper select.field-error {\n  border-color: #c62828;\n}\n\n\/* ===== Ref Code Strip ===== *\/\n.ref-strip {\n  display: flex;\n  align-items: center;\n  gap: 14px;\n  background: #f9f9f9;\n  border: 1px solid #ddd;\n  border-radius: 8px;\n  padding: 14px 16px;\n  margin-bottom: 20px;\n}\n.ref-strip-icon {\n  font-size: 22px;\n  flex-shrink: 0;\n}\n.ref-strip-body {\n  flex: 1;\n}\n.ref-strip-body label {\n  margin-bottom: 6px;\n}\n.ref-strip-body input {\n  margin-bottom: 0;\n}\n\n\/* ===== Sample Items — same strip style as ref code ===== *\/\n.sample-policy {\n  background: #eef4ff;\n  border: 1px solid #c0d4f9;\n  border-radius: 8px;\n  padding: 12px 16px;\n  margin-bottom: 20px;\n  font-size: 13px;\n  color: #2550a8;\n  line-height: 1.6;\n}\n.sample-policy strong { font-weight: 600; }\n\n.sample-item {\n  display: flex;\n  align-items: center;\n  gap: 14px;\n  background: #f9f9f9;\n  border: 1px solid #ddd;\n  border-radius: 8px;\n  padding: 14px 16px;\n  margin-bottom: 12px;\n}\n.sample-item-icon {\n  font-size: 22px;\n  flex-shrink: 0;\n}\n.sample-item-body {\n  flex: 1;\n  display: flex;\n  gap: 14px;\n}\n.sample-item-body > div { flex: 1; }\n.sample-item-body label { margin-bottom: 6px; }\n.sample-item-body input,\n.sample-item-body select { margin-bottom: 0; }\n\n.sample-item-remove {\n  background: none;\n  border: 1px solid #ddd;\n  border-radius: 6px;\n  width: 34px;\n  height: 34px;\n  font-size: 16px;\n  color: #999;\n  cursor: pointer;\n  flex-shrink: 0;\n  transition: all 0.2s ease;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n.sample-item-remove:hover { border-color: #c62828; color: #c62828; background: #fff5f5; }\n.sample-item-remove:disabled { opacity: 0.3; cursor: not-allowed; }\n.sample-item-remove:disabled:hover { border-color: #ddd; color: #999; background: none; }\n\n.add-item-btn {\n  width: 100%;\n  padding: 12px;\n  background: none;\n  border: 1px dashed #4a8df6;\n  border-radius: 8px;\n  color: #4a8df6;\n  font-size: 14px;\n  font-weight: 500;\n  cursor: pointer;\n  transition: all 0.2s ease;\n  font-family: inherit;\n  margin-bottom: 6px;\n}\n.add-item-btn:hover { background: #f0f7ff; }\n.add-item-btn:disabled { opacity: 0.4; cursor: not-allowed; }\n.add-item-btn:disabled:hover { background: none; }\n\n.sample-counter {\n  font-size: 12px;\n  color: #999;\n  text-align: right;\n  margin-bottom: 20px;\n}\n.sample-error {\n  font-size: 13px;\n  color: #c62828;\n  margin-bottom: 16px;\n  display: none;\n}\n\n\/* ===== Buttons ===== *\/\n.form-buttons {\n  display: flex;\n  gap: 15px;\n  margin-top: 10px;\n}\n.btn {\n  flex: 1;\n  padding: 14px;\n  border: none;\n  border-radius: 8px;\n  font-size: 15px;\n  font-weight: 600;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  font-family: inherit;\n}\n.btn-primary { background: #4a8df6; color: #fff; }\n.btn-primary:hover { background: #3a75d6; }\n\n\/* ===== Success ===== *\/\n.sample-success {\n  text-align: center;\n  display: none;\n}\n.sample-success.active {\n  display: block;\n  animation: fadeIn 0.4s ease;\n}\n@keyframes fadeIn {\n  from { opacity: 0; transform: translateY(10px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n.success-icon {\n  width: 80px;\n  height: 80px;\n  background: #e6f4ea;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 40px;\n  margin: 0 auto 20px;\n}\n.sample-success h2 { color: #1e7e34; margin-bottom: 15px; }\n.sample-success p { color: #666; font-size: 16px; line-height: 1.6; margin-bottom: 30px; }\n.success-buttons {\n  display: flex;\n  gap: 15px;\n  margin-top: 30px;\n}\n.success-buttons a {\n  flex: 1;\n  padding: 14px 20px;\n  text-align: center;\n  text-decoration: none;\n  border-radius: 8px;\n  font-size: 15px;\n  font-weight: 600;\n  transition: all 0.3s ease;\n}\n.btn-shop { background: #4a8df6; color: #fff; }\n.btn-shop:hover {\n  background: #3a75d6;\n  transform: translateY(-2px);\n  box-shadow: 0 4px 12px rgba(74,141,246,0.3);\n}\n.btn-apply {\n  background: #fff;\n  color: #4a8df6;\n  border: 2px solid #4a8df6;\n}\n.btn-apply:hover {\n  background: #f0f7ff;\n  transform: translateY(-2px);\n  box-shadow: 0 4px 12px rgba(74,141,246,0.2);\n}\n\n@media (max-width: 768px) {\n  .sample-form-wrapper { padding: 30px 20px; }\n  .sample-item-body { flex-direction: column; gap: 0; }\n  .success-buttons { flex-direction: column; }\n  .form-buttons { flex-direction: column; }\n}\n<\/style>\n\n<!-- OWELL Header -->\n<div style=\"background:#0a1628;padding:14px 40px;display:flex;align-items:center;border-bottom:2px solid #c9a84c; justify-content: center;\">\n  <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0403\/6057\/5138\/files\/Asset_2hat.png?v=1753811629\" alt=\"OWELL® Logo\" style=\"height:48px;width:auto;display:block;\">\n<\/div>\n\n<!-- Hero Banner -->\n<div style=\"background:linear-gradient(135deg,#0a1628 0%,#162a5c 60%,#1e3a7a 100%);padding:48px 40px 44px;text-align:center;margin-bottom:40px;\">\n  <div style=\"display:inline-block;background:rgba(201,168,76,0.15);border:1px solid rgba(201,168,76,0.4);color:#c9a84c;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;padding:6px 16px;border-radius:40px;margin-bottom:16px;\">Qualified Businesses Only<\/div>\n  <h1 style=\"font-size:clamp(24px,4vw,38px);font-weight:700;color:#fff;line-height:1.2;margin:0 0 12px;\">Request a Complimentary Sample Box<\/h1>\n  <p style=\"font-size:15px;color:rgba(255,255,255,0.65);max-width:460px;margin:0 auto;line-height:1.65;\">Designed for qualified businesses evaluating OWELL® for professional use.<\/p>\n<\/div>\n\n<div class=\"sample-form-wrapper\">\n\n  <form id=\"sampleForm\">\n    <h2>Sample Request<\/h2>\n    <p class=\"form-subtitle\">Fill out the form below and our team will ship your samples within 2–3 business days.<\/p>\n\n    <label>First Name *<\/label>\n    <input type=\"text\" name=\"first_name\" required placeholder=\"Jane\">\n\n    <label>Last Name *<\/label>\n    <input type=\"text\" name=\"last_name\" required placeholder=\"Smith\">\n\n    <label>Business Email Address *<\/label>\n    <input type=\"email\" name=\"email\" required placeholder=\"jane@yourcompany.com\">\n\n    <label>Business Name *<\/label>\n    <input type=\"text\" name=\"business_name\" required placeholder=\"Your Company Inc.\">\n\n    <label>Business Type *<\/label>\n    <select name=\"business_type\" required>\n      <option value=\"\">Select your business type<\/option>\n      <option value=\"Medical \/ Dental\">Medical \/ Dental<\/option>\n      <option value=\"Food Service \/ Hospitality\">Food Service \/ Hospitality<\/option>\n      <option value=\"Janitorial \/ Facility\">Janitorial \/ Facility<\/option>\n      <option value=\"Retail\">Retail<\/option>\n      <option value=\"Laboratory \/ Drug Testing\">Laboratory \/ Drug Testing<\/option>\n      <option value=\"Other\">Other<\/option>\n    <\/select>\n\n    <!-- Ref Code — strip style -->\n    <div class=\"ref-strip\">\n      <div class=\"ref-strip-icon\">🏷️<\/div>\n      <div class=\"ref-strip-body\">\n        <label class=\"optional\">Referral \/ Promo Code (Optional)<\/label>\n        <input type=\"text\" name=\"ref_code\" placeholder=\"e.g. OWELL25\" maxlength=\"20\">\n      <\/div>\n    <\/div>\n\n    <!-- Sample Items — same strip style -->\n    <label>Sample Items Requested *<\/label>\n    <div class=\"sample-policy\">\n      <strong>Sample Policy:<\/strong> Up to <strong>3 sample items<\/strong> per request. <strong>1 sample per product category<\/strong> (e.g. one glove style, one trash bag style). Enter the Item # as listed on our website or catalog.\n    <\/div>\n\n    <div id=\"sampleItems\">\n\n      <div class=\"sample-item\" data-item=\"1\">\n        <div class=\"sample-item-icon\">📦<\/div>\n        <div class=\"sample-item-body\">\n          <div>\n            <label>Category *<\/label>\n            <select name=\"category_1\">\n              <option value=\"\">Select category…<\/option>\n              <option value=\"Gloves\">Gloves<\/option>\n              <option value=\"Trash Bags\">Trash Bags<\/option>\n              <option value=\"Masks \/ PPE\">Masks \/ PPE<\/option>\n              <option value=\"Lab Supplies\">Lab Supplies<\/option>\n              <option value=\"Cleaning Supplies\">Cleaning Supplies<\/option>\n              <option value=\"Food Service Supplies\">Food Service Supplies<\/option>\n              <option value=\"Other\">Other<\/option>\n            <\/select>\n          <\/div>\n          <div>\n            <label>Item # *<\/label>\n            <input type=\"text\" name=\"item_1\" placeholder=\"e.g. OW-GL-100\" required>\n          <\/div>\n        <\/div>\n        <button type=\"button\" class=\"sample-item-remove\" onclick=\"removeItem(this)\" disabled title=\"Remove\">✕<\/button>\n      <\/div>\n\n    <\/div>\n\n    <button type=\"button\" class=\"add-item-btn\" id=\"addItemBtn\" onclick=\"addItem()\">+ Add Another Sample<\/button>\n    <div class=\"sample-counter\">Items selected: <span id=\"itemCount\">1<\/span> \/ 3<\/div>\n    <div class=\"sample-error\" id=\"sampleError\">Please select at least one sample category.<\/div>\n\n    <div class=\"form-buttons\">\n      <button type=\"submit\" class=\"btn btn-primary\">Submit Sample Request<\/button>\n    <\/div>\n  <\/form>\n\n  <!-- Success Message -->\n  <div class=\"sample-success\" id=\"successMessage\">\n    <div class=\"success-icon\">✓<\/div>\n    <h2>Sample Request Received!<\/h2>\n    <p>\n      Our team will review your request and ship your samples within 2–3 business days.<br>\n      <strong>We'll follow up by email with your tracking details.<\/strong>\n    <\/p>\n    <div class=\"success-buttons\">\n      <a href=\"https:\/\/owell.com\/collections\/owell-disposable-gloves\" class=\"btn-shop\">Shop Gloves<\/a>\n      <a href=\"https:\/\/owell.com\/pages\/owell-wholesale-bulk-purchasing\" class=\"btn-apply\">Apply for Business Account<\/a>\n    <\/div>\n  <\/div>\n\n<\/div>\n\n<script>\nlet itemCount = 1;\nconst MAX_ITEMS = 3;\n\nconst categoryOptions = `\n  <option value=\"\">Select category…<\/option>\n  <option value=\"Gloves\">Gloves<\/option>\n  <option value=\"Trash Bags\">Trash Bags<\/option>\n  <option value=\"Masks \/ PPE\">Masks \/ PPE<\/option>\n  <option value=\"Lab Supplies\">Lab Supplies<\/option>\n  <option value=\"Cleaning Supplies\">Cleaning Supplies<\/option>\n  <option value=\"Food Service Supplies\">Food Service Supplies<\/option>\n  <option value=\"Other\">Other<\/option>\n`;\n\nfunction updateUI() {\n  document.getElementById('itemCount').textContent = itemCount;\n  document.getElementById('addItemBtn').disabled = itemCount >= MAX_ITEMS;\n  const items = document.querySelectorAll('.sample-item');\n  items.forEach(item => {\n    item.querySelector('.sample-item-remove').disabled = items.length === 1;\n  });\n}\n\nfunction addItem() {\n  if (itemCount >= MAX_ITEMS) return;\n  itemCount++;\n  const container = document.getElementById('sampleItems');\n  const div = document.createElement('div');\n  div.className = 'sample-item';\n  div.dataset.item = itemCount;\n  div.innerHTML = `\n    <div class=\"sample-item-icon\">📦<\/div>\n    <div class=\"sample-item-body\">\n      <div>\n        <label>Category *<\/label>\n        <select name=\"category_${itemCount}\">${categoryOptions}<\/select>\n      <\/div>\n      <div>\n        <label>Item # *<\/label>\n        <input type=\"text\" name=\"item_${itemCount}\" placeholder=\"e.g. OW-GL-100\" required>\n      <\/div>\n    <\/div>\n    <button type=\"button\" class=\"sample-item-remove\" onclick=\"removeItem(this)\" title=\"Remove\">✕<\/button>\n  `;\n  container.appendChild(div);\n  div.querySelector('select').focus();\n  updateUI();\n}\n\nfunction removeItem(btn) {\n  const items = document.querySelectorAll('.sample-item');\n  if (items.length <= 1) return;\n  btn.closest('.sample-item').remove();\n  itemCount--;\n  updateUI();\n}\n\ndocument.getElementById('sampleForm').addEventListener('submit', function(e) {\n  e.preventDefault();\n  let allValid = true;\n\n  \/\/ Validate required fields\n  this.querySelectorAll('[required]').forEach(field => {\n    if (!field.value.trim()) {\n      allValid = false;\n      field.classList.add('field-error');\n    } else {\n      field.classList.remove('field-error');\n    }\n  });\n\n  \/\/ Validate Item # fields inside sample items\n  document.querySelectorAll('.sample-item input[type=\"text\"]').forEach(input => {\n    if (!input.value.trim()) {\n      allValid = false;\n      input.classList.add('field-error');\n    } else {\n      input.classList.remove('field-error');\n    }\n  });\n\n  \/\/ Validate email format\n  const emailField = this.querySelector('[name=\"email\"]');\n  if (emailField.value && !\/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$\/.test(emailField.value)) {\n    allValid = false;\n    emailField.classList.add('field-error');\n  }\n\n  \/\/ Validate sample categories\n  const selects = document.querySelectorAll('.sample-item select');\n  let anySelected = false;\n  let hasDupe = false;\n  const seen = [];\n  selects.forEach(sel => {\n    if (sel.value) {\n      if (seen.includes(sel.value)) hasDupe = true;\n      seen.push(sel.value);\n      anySelected = true;\n    }\n  });\n\n  const sampleError = document.getElementById('sampleError');\n  if (!anySelected) {\n    sampleError.textContent = 'Please select at least one sample category.';\n    sampleError.style.display = 'block';\n    allValid = false;\n  } else if (hasDupe) {\n    sampleError.textContent = 'Only 1 sample per category allowed. Please remove the duplicate.';\n    sampleError.style.display = 'block';\n    allValid = false;\n  } else {\n    sampleError.style.display = 'none';\n  }\n\n  if (!allValid) {\n    const firstErr = this.querySelector('.field-error');\n    if (firstErr) firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });\n    return;\n  }\n\n  \/\/ Show success\n  document.getElementById('sampleForm').style.display = 'none';\n  document.getElementById('successMessage').classList.add('active');\n  document.querySelector('.sample-form-wrapper').scrollIntoView({ behavior: 'smooth' });\n});\n<\/script>","padding_top":52,"padding_bottom":52,"color_scheme":""}}},"order":["main","image_text_sectionn_M6Kqk4","rich_text_JdmQRA","core_areas_section_qVttYn","media_and_text_6UKRgB","custom_liquid_AYVqq6","custom_liquid_LcGiMR","wholesale_a8YjcW","custom_liquid_yAUgrb"]}